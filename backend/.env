# 保研信息助手小程序 - 开发环境配置
# 环境: development
# 创建日期: 2026-02-25

# ==========================================
# 数据库配置
# ==========================================
# SQLite (开发环境) - 轻量级，无需安装MySQL
DATABASE_URL="file:./dev.db"

# MySQL (生产环境) - 取消注释以下行并注释上面的SQLite配置
# DATABASE_URL="mysql://root:root@localhost:3306/baoyan?schema=public"

# ==========================================
# Redis配置
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# 微信小程序配置
# ==========================================
# 请替换为您的微信小程序 AppID 和 Secret
WECHAT_APPID=wx_appid_placeholder
WECHAT_SECRET=wx_secret_placeholder

# ==========================================
# JWT配置
# ==========================================
# 请替换为强密钥（生产环境必须使用复杂随机字符串）
JWT_SECRET=baoyan_jwt_secret_key_development_2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# DeepSeek API配置
# ==========================================
# 请替换为您的 DeepSeek API Key
DEEPSEEK_API_KEY=sk-placeholder-replace-with-your-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# ==========================================
# 服务器配置
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=debug
LOG_DIR=./logs

# ==========================================
# 爬虫配置
# ==========================================
# 爬虫速率限制（秒）
CRAWLER_DELAY=30
# 代理池（可选，多个代理用逗号分隔）
PROXY_POOL=

# ==========================================
# 阿里云OSS配置（可选）
# ==========================================
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=

# ==========================================
# 提醒服务配置
# ==========================================
# 微信订阅消息模板ID（需要在微信小程序后台申请）
WX_SUBSCRIBE_TEMPLATE_ID=
# 提醒服务定时任务Cron表达式
REMINDER_CRON="0 */1 * * * *"

# ==========================================
# API限流配置
# ==========================================
# 每分钟请求限制
RATE_LIMIT_PER_MINUTE=100
# 每小时请求限制
RATE_LIMIT_PER_HOUR=1000
