# 保研信息助手小程序 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL="mysql://username:password@localhost:3306/baoyan?schema=public"

# ==========================================
# Redis配置
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# 微信小程序配置
# ==========================================
WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here
WX_PROGRESS_CHANGE_TEMPLATE_ID=
# 仅开发/测试环境可开启，生产环境必须为false
ALLOW_MOCK_WECHAT_LOGIN=false
# openid安全存储密钥（必须为32字节）
OPENID_HMAC_KEY=replace_with_32_byte_key
OPENID_ENCRYPTION_KEY=replace_with_32_byte_key

# ==========================================
# JWT配置
# ==========================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# DeepSeek API配置
# ==========================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1
# 规则抽取触发缺失/冲突/低置信度时，是否启用 DeepSeek 兜底
DEEPSEEK_FALLBACK_ENABLED=false
# 当规则抽取 confidence 低于该阈值时触发兜底（0-1）
DEEPSEEK_FALLBACK_MIN_CONFIDENCE=0.75
# 提取版本号（用于审计/回放）
DEEPSEEK_EXTRACTION_VERSION=deepseek-fallback-v1
# 调用模型名（审计记录）
DEEPSEEK_MODEL=deepseek-chat
# 入库审计保留的 source snippet 最大长度
DEEPSEEK_SOURCE_SNIPPET_MAX_LENGTH=1500

# ==========================================
# 服务器配置
# ==========================================
PORT=3000
NODE_ENV=development
# CORS白名单，多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=info
LOG_DIR=./logs

# ==========================================
# 爬虫入库配置
# ==========================================
# Python 爬虫调用 POST /api/v1/crawler/ingest-camps 时使用
CRAWLER_INGEST_KEY=replace_with_strong_shared_secret

# ==========================================
# 阿里云OSS配置（可选）
# ==========================================
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=
