// 保研信息助手小程序 - Prisma Schema
// 数据库模型定义
// 支持: MySQL (生产环境) / SQLite (开发环境)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id           String   @id @default(uuid())
  openid       String?  @unique
  openidHash   String?  @unique
  openidCipher String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 关联
  selection UserSelection?
  reminders Reminder[]
  progresses ApplicationProgress[]
  progressSubscriptions ProgressSubscription[]
  progressAlerts ProgressAlert[]

  @@index([openidHash])
  @@map("users")
}

// 院校表
model University {
  id       String @id @default(uuid())
  name     String
  logo     String?
  region   String?
  level    String? // 985/211/双一流/普通
  website  String?
  priority String  @default("P3") // P0/P1/P2/P3
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  majors   Major[]
  campInfos CampInfo[]

  @@index([name])
  @@index([region])
  @@index([level])
  @@index([priority])
  @@map("universities")
}

// 专业表
model Major {
  id       String @id @default(uuid())
  name     String
  category String?
  
  universityId String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  university University @relation(fields: [universityId], references: [id])
  campInfos  CampInfo[]

  @@index([name])
  @@index([category])
  @@index([universityId])
  @@map("majors")
}

// 夏令营信息表
model CampInfo {
  id          String   @id @default(uuid())
  title       String
  announcementType String @default("summer_camp") // summer_camp/pre_recommendation
  sourceUrl   String
  
  universityId String
  majorId      String?
  
  publishDate DateTime?
  deadline    DateTime?
  startDate   DateTime?
  endDate     DateTime?
  
  requirements String? // 申请要求（JSON字符串）
  materials    String? // 所需材料清单（JSON字符串）
  process      String? // 报名流程步骤（JSON字符串）
  
  status     String   @default("published") // draft/published/expired
  confidence Float    @default(1.00) // 信息置信度 0-1
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  university University   @relation(fields: [universityId], references: [id])
  major      Major?       @relation(fields: [majorId], references: [id])
  reminders  Reminder[]
  progresses ApplicationProgress[]
  progressChangeEvents ProgressChangeEvent[]
  progressAlerts ProgressAlert[]

  @@index([universityId])
  @@index([majorId])
  @@index([deadline])
  @@index([status])
  @@index([publishDate])
  @@index([announcementType])
  @@map("camp_infos")
}

// 用户选择表
model UserSelection {
  id       String @id @default(uuid())
  userId   String @unique
  
  universityIds String? // 关注的院校ID列表（JSON字符串）
  majorIds      String? // 关注的专业ID列表（JSON字符串）
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_selections")
}

// 提醒表
model Reminder {
  id          String   @id @default(uuid())
  userId      String
  campId      String
  remindTime  DateTime
  status      String   @default("pending") // pending/sent/failed/expired
  templateId  String?
  sentAt      DateTime?
  errorMsg    String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  camp CampInfo @relation(fields: [campId], references: [id], onDelete: Cascade)

  // 索引优化
  @@index([userId])
  @@index([campId])
  @@index([status])
  @@index([remindTime])
  @@index([userId, createdAt]) // 复合索引：优化用户提醒列表查询
  @@index([userId, status])    // 复合索引：优化用户按状态筛选查询
  @@map("reminders")
}

// 爬虫任务日志表
model CrawlerLog {
  id           String   @id @default(uuid())
  universityId String
  status       String // success/failed/running
  startTime    DateTime
  endTime      DateTime?
  errorMsg     String?
  itemsCount   Int      @default(0)
  
  createdAt DateTime @default(now())

  @@index([universityId])
  @@index([status])
  @@index([createdAt])
  @@map("crawler_logs")
}

// API调用日志表（用于成本监控）
model ApiCallLog {
  id        String   @id @default(uuid())
  apiType   String // deepseek/wechat
  callCount Int      @default(1)
  cost      Float    @default(0) // 成本（元）
  status    String // success/failed
  errorMsg  String?
  
  createdAt DateTime @default(now())

  @@index([apiType])
  @@index([createdAt])
  @@map("api_call_logs")
}

// 申请进展表
model ApplicationProgress {
  id        String   @id @default(uuid())
  userId    String
  campId    String
  status    String   @default("followed") // followed/preparing/submitted/waiting_admission/admitted/waiting_outstanding/outstanding_published
  nextAction String?
  statusNote String?
  lastStatusAt DateTime @default(now())
  submittedAt DateTime?
  admissionPublishedAt DateTime?
  admittedAt DateTime?
  outstandingPublishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  camp CampInfo @relation(fields: [campId], references: [id], onDelete: Cascade)
  statusLogs ProgressStatusLog[]
  subscription ProgressSubscription?
  alerts ProgressAlert[]

  @@unique([userId, campId])
  @@index([userId, status])
  @@index([campId])
  @@index([updatedAt])
  @@map("application_progresses")
}

// 申请进展状态日志
model ProgressStatusLog {
  id         String   @id @default(uuid())
  progressId String
  fromStatus String?
  toStatus   String
  note       String?
  changedAt  DateTime @default(now())

  progress ApplicationProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@index([progressId, changedAt])
  @@map("progress_status_logs")
}

// 结果/变更订阅
model ProgressSubscription {
  id        String   @id @default(uuid())
  progressId String  @unique
  userId    String
  deadlineChanged           Boolean @default(true)
  materialsChanged          Boolean @default(true)
  admissionResultChanged    Boolean @default(true)
  outstandingResultChanged  Boolean @default(true)
  enabled   Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress ApplicationProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@map("progress_subscriptions")
}

// 来自爬虫/运营的变更事件
model ProgressChangeEvent {
  id          String   @id @default(uuid())
  campId       String
  eventType    String // deadline/materials/admission_result/outstanding_result
  fieldName    String?
  oldValue     String?
  newValue     String?
  sourceType   String   @default("crawler") // crawler/manual/system
  sourceUrl    String?
  sourceUpdatedAt DateTime?
  confidenceLabel String @default("medium") // high/medium/low
  confidenceScore Float  @default(0.6)
  createdAt    DateTime @default(now())

  camp CampInfo @relation(fields: [campId], references: [id], onDelete: Cascade)
  alerts ProgressAlert[]

  @@index([campId, createdAt])
  @@index([eventType, createdAt])
  @@index([confidenceLabel])
  @@map("progress_change_events")
}

// 进展提醒/订阅消息
model ProgressAlert {
  id          String   @id @default(uuid())
  userId      String
  progressId  String?
  campId      String?
  eventId     String?
  type        String // deadline_stage/result_watch/change_event
  title       String
  content     String
  status      String  @default("pending") // pending/handled/snoozed
  priority    String  @default("normal") // normal/high/urgent
  confidenceLabel String?
  scheduledAt DateTime @default(now())
  snoozeUntil DateTime?
  handledAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress ApplicationProgress? @relation(fields: [progressId], references: [id], onDelete: SetNull)
  camp CampInfo? @relation(fields: [campId], references: [id], onDelete: SetNull)
  event ProgressChangeEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, status, scheduledAt])
  @@index([progressId])
  @@index([campId])
  @@index([eventId])
  @@map("progress_alerts")
}
