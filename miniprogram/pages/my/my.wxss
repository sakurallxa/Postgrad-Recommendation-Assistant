.page {
  padding: var(--space-5) var(--space-3) calc(env(safe-area-inset-bottom) + var(--space-5));
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-5) var(--space-3) var(--space-6);
}
.avatar-wrap {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), #818CF8);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-3);
  box-shadow: 0 12rpx 32rpx rgba(79, 70, 229, 0.32);
}
.avatar {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: var(--weight-bold);
}
.hero-name {
  font-size: var(--text-xl);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.hero-meta {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

.menu-card {
  background: var(--bg-surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  margin: 0 var(--space-2) var(--space-4);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-4);
  border-bottom: 1rpx solid var(--border-light);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: var(--bg-muted); }

.menu-icon {
  font-size: 44rpx;
  margin-right: var(--space-3);
  flex-shrink: 0;
}
.menu-text { flex: 1; }
.menu-title {
  font-size: var(--text-md);
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.menu-desc {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}
.menu-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 200;
  margin-left: var(--space-2);
}

.footer-tip {
  text-align: center;
  color: var(--text-disabled);
  font-size: var(--text-xs);
  padding: var(--space-4) 0;
}

.logout-btn {
  margin: var(--space-5) var(--space-2) var(--space-3);
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: var(--bg-surface);
  color: var(--color-danger);
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-danger-soft);
  transition: transform 0.12s;
}
.logout-btn:active {
  background: var(--color-danger-soft);
  transform: scale(0.99);
}

.login-btn {
  margin-top: var(--space-3);
  padding: 0 var(--space-6);
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--color-primary), #818CF8);
  color: #FFFFFF;
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(79, 70, 229, 0.25);
}
.login-btn:active { transform: scale(0.98); opacity: 0.9; }
.login-btn-disabled { opacity: 0.6; pointer-events: none; }
