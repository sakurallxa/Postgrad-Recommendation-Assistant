/* 个人中心页面样式 */

.container {
  padding: var(--spacing-lg);
  background-color: var(--background-light);
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-info-card {
  background: linear-gradient(135deg, var(--primary-color) 0%, #4285F4 100%);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  display: flex;
  align-items: center;
  color: white;
  box-shadow: var(--shadow-2);
}

.user-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: var(--spacing-lg);
  border: 2px solid rgba(255, 255, 255, 0.3);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-details {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: var(--spacing-xs);
  display: block;
}

.user-openid {
  font-size: 14px;
  opacity: 0.8;
  display: block;
}

.login-btn {
  background-color: white;
  color: var(--primary-color);
  border: none;
  border-radius: var(--border-radius-sm);
  padding: var(--spacing-xs) var(--spacing-lg);
  font-size: 14px;
  font-weight: 500;
}

.login-btn::after {
  border-radius: var(--border-radius-sm);
}

/* 功能菜单 */
.menu-section {
  background-color: var(--background-white);
  border-radius: var(--border-radius-md);
  box-shadow: var(--shadow-1);
  margin-bottom: var(--spacing-lg);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: 1px solid var(--border-color);
  transition: background-color 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--background-light);
}

.menu-icon {
  font-size: 24px;
  margin-right: var(--spacing-md);
  min-width: 32px;
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.menu-desc {
  font-size: 14px;
  color: var(--text-secondary);
  display: block;
}

.menu-arrow {
  font-size: 16px;
  color: var(--text-tertiary);
  margin-left: var(--spacing-sm);
}

/* 版本信息 */
.version-info {
  text-align: center;
  margin-bottom: var(--spacing-lg);
  font-size: 14px;
  color: var(--text-tertiary);
}

/* 免责声明 */
.disclaimer {
  background-color: var(--background-white);
  border-radius: var(--border-radius-md);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-1);
}

.disclaimer-text {
  font-size: 12px;
  color: var(--text-tertiary);
  line-height: 1.5;
  text-align: center;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .user-info-card {
    padding: var(--spacing-lg);
  }
  
  .user-avatar {
    width: 56px;
    height: 56px;
  }
  
  .user-name {
    font-size: 16px;
  }
  
  .menu-item {
    padding: var(--spacing-md);
  }
  
  .menu-title {
    font-size: 15px;
  }
  
  .menu-desc {
    font-size: 13px;
  }
}