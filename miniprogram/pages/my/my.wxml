<view class="page">
  <view class="hero">
    <view class="avatar-wrap">
      <view class="avatar">{{avatarInitial}}</view>
    </view>
    <view class="hero-name">{{userName}}</view>

    <!-- 未登录态 -->
    <block wx:if="{{!isLoggedIn}}">
      <view class="hero-meta">登录后查看个人档案与订阅</view>
      <view class="login-btn {{loginPending ? 'login-btn-disabled' : ''}}" bindtap="onLogin">
        {{loginPending ? '登录中...' : '微信一键登录'}}
      </view>
    </block>

    <!-- 已登录态 -->
    <block wx:else>
      <view class="hero-meta" wx:if="{{profile.completeness > 0}}">档案完整度 {{profile.completeness}}%</view>
      <view class="hero-meta" wx:else>未填写档案</view>
    </block>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="goProfile">
      <view class="menu-icon">🎯</view>
      <view class="menu-text">
        <view class="menu-title">个人档案</view>
        <view class="menu-desc">{{profile.exists ? '已填写 · 点击修改' : '完善后 AI 匹配更精准'}}</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goSelector">
      <view class="menu-icon">🏫</view>
      <view class="menu-text">
        <view class="menu-title">关注的院系</view>
        <view class="menu-desc">已订阅 {{subscribedCount}} 个院系</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goSubmitUrl">
      <view class="menu-icon">🔗</view>
      <view class="menu-text">
        <view class="menu-title">手动测试 AI 助理</view>
        <view class="menu-desc">贴 URL 让 AI 分析匹配度</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <view class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="onLogout">退出登录</view>

  <view class="footer-tip">v0.2 · AI 保研助理</view>
</view>
