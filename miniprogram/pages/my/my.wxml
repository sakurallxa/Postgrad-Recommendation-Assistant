<view class="container">
  <!-- 用户信息区 -->
  <view class="user-info-card">
    <view class="user-avatar">
      <image src="{{userInfo.avatar || 'https://example.com/avatar/default.png'}}" mode="aspectFill" />
    </view>
    <view class="user-details">
      <text class="user-name">{{userInfo.nickname || '未登录'}}</text>
      <text class="user-openid">{{userInfo.openid ? '已登录' : '点击登录'}}</text>
    </view>
    <button wx:if="{{!isLoggedIn}}" class="login-btn" bindtap="handleLogin">
      微信登录
    </button>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="navigateToSelector">
      <view class="menu-icon">🎓</view>
      <view class="menu-content">
        <text class="menu-title">目标院校管理</text>
        <text class="menu-desc">管理关注的院校和专业</text>
      </view>
      <view class="menu-arrow">→</view>
    </view>
    
    <view class="menu-item" bindtap="navigateToReminders">
      <view class="menu-icon">🔔</view>
      <view class="menu-content">
        <text class="menu-title">我的提醒</text>
        <text class="menu-desc">查看和管理设置的提醒</text>
      </view>
      <view class="menu-arrow">→</view>
    </view>
    
    <view class="menu-item" bindtap="handleFeedback">
      <view class="menu-icon">💬</view>
      <view class="menu-content">
        <text class="menu-title">意见反馈</text>
        <text class="menu-desc">提交建议和问题</text>
      </view>
      <view class="menu-arrow">→</view>
    </view>
    
    <view class="menu-item" bindtap="handleAbout">
      <view class="menu-icon">ℹ️</view>
      <view class="menu-content">
        <text class="menu-title">关于我们</text>
        <text class="menu-desc">了解保研信息助手</text>
      </view>
      <view class="menu-arrow">→</view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>版本号: v1.0.0</text>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer">
    <text class="disclaimer-text">
      免责声明：本小程序提供的夏令营信息仅供参考，具体信息以院校官网为准。
    </text>
  </view>
</view>