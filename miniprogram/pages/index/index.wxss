/* 首页样式 */

.container {
  padding: var(--spacing-lg);
  background-color: var(--background-light);
  min-height: 100vh;
}

/* 问候区 */
.greeting-card {
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--background-white) 100%);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-1);
}

.greeting-text {
  font-size: 20px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
  display: block;
}

.stats-text {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 区块通用样式 */
.section {
  margin-bottom: var(--spacing-xl);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-header-vertical {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
}

.section-header-vertical .section-title {
  margin-bottom: var(--spacing-md);
}

.section-header-vertical .filter-bar {
  width: 100%;
}

.follow-entry-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
  border: 1px solid rgba(26, 115, 232, 0.16);
  border-radius: var(--border-radius-md);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-1);
}

.follow-entry-summary {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10px;
}

.follow-entry-desc {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}

.follow-entry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 2px;
}

.follow-entry-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 28px;
  font-size: 12px;
  color: var(--primary-dark);
  background: rgba(26, 115, 232, 0.1);
  border: 1px solid rgba(26, 115, 232, 0.2);
  padding: 0 10px;
  border-radius: var(--border-radius-full);
  text-align: center;
}

.follow-entry-tag.more {
  color: var(--text-secondary);
  background: var(--background-white);
}

.follow-entry-tag-text {
  line-height: 1;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
}

.section-subtext {
  font-size: 12px;
  color: var(--text-tertiary);
  margin-top: -6px;
  margin-bottom: var(--spacing-sm);
}

.section-more {
  font-size: 14px;
  color: var(--primary-color);
  display: flex;
  align-items: center;
  margin-left: auto;
  flex-shrink: 0;
  white-space: nowrap;
}

.arrow-right {
  margin-left: var(--spacing-xs);
  font-size: 12px;
}

/* 即将截止区 */
.urgent-camps {
  margin-top: var(--spacing-md);
}

.urgent-card {
  display: flex;
  align-items: center;
  background-color: var(--background-white);
  border-radius: var(--border-radius-md);
  box-shadow: var(--shadow-2);
  padding: var(--spacing-lg);
  width: 100%;
  margin-bottom: var(--spacing-md);
}

.countdown {
  display: flex;
  align-items: baseline;
  margin-right: var(--spacing-md);
  min-width: 60px;
}

.countdown-number {
  font-size: 28px;
  font-weight: 700;
  line-height: 1;
}

.countdown-unit {
  font-size: 14px;
  font-weight: 500;
  margin-left: var(--spacing-xs);
}

.countdown.urgent {
  color: var(--warning-color);
}

.countdown.expired {
  color: var(--error-color);
}

.countdown.normal {
  color: var(--success-color);
}

.urgent-info {
  flex: 1;
  min-width: 0;
}

.urgent-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: var(--spacing-sm);
}

.university-name {
  display: inline-flex;
  align-items: center;
  font-size: 12px;
  font-weight: 600;
  color: var(--primary-color);
  background: linear-gradient(135deg, var(--primary-light) 0%, rgba(74, 144, 226, 0.15) 100%);
  min-height: 22px;
  padding: 0 10px;
  line-height: 1.1;
  border-radius: var(--border-radius-sm);
  border: 1px solid rgba(74, 144, 226, 0.2);
}

.urgent-announcement-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 600;
  height: 20px;
  padding: 0 7px;
  line-height: 1;
  border-radius: 4px;
  border: 1px solid transparent;
  letter-spacing: 0;
  flex-shrink: 0;
}

.urgent-announcement-badge text {
  line-height: 1;
}

.urgent-announcement-badge.summer-camp {
  color: #185abc;
  background: rgba(45, 108, 223, 0.08);
  border-color: rgba(45, 108, 223, 0.32);
}

.urgent-announcement-badge.pre-recommendation {
  color: #b05a00;
  background: rgba(255, 167, 38, 0.12);
  border-color: rgba(255, 167, 38, 0.35);
}

.camp-title {
  font-size: 14px;
  font-weight: 400;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: var(--spacing-xs);
  line-height: 1.4;
}

.deadline {
  font-size: 12px;
  color: var(--text-tertiary);
  display: block;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--spacing-sm);
}

.filter-row {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
}

.filter-label {
  flex-shrink: 0;
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 30px;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-item {
  display: inline-flex;
  font-size: 14px;
  color: var(--text-secondary);
  padding: 6px 16px;
  border-radius: var(--border-radius-full);
  background-color: var(--background-white);
  border: 1px solid var(--border-color);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.2s ease;
  margin-right: var(--spacing-sm);
}

.filter-item.active {
  color: var(--primary-color);
  border-color: var(--primary-color);
  background-color: var(--primary-light);
  font-weight: 500;
}

/* 夏令营列表 */
.camp-list {
  margin-top: var(--spacing-md);
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
  color: var(--text-tertiary);
  font-size: 14px;
}

.loading-text {
  margin-left: var(--spacing-sm);
}

.no-more {
  text-align: center;
  padding: var(--spacing-lg);
  color: var(--text-tertiary);
  font-size: 14px;
}

.my-camps-empty {
  background: var(--background-white);
  border-radius: var(--border-radius-md);
  border: 1px solid rgba(26, 115, 232, 0.14);
  padding: var(--spacing-lg);
  text-align: center;
}

.my-camps-empty-text {
  display: block;
  font-size: 14px;
  color: var(--text-secondary);
}

.my-camps-empty-action {
  margin-top: var(--spacing-sm);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6px 14px;
  border-radius: var(--border-radius-full);
  color: var(--primary-color);
  border: 1px solid var(--primary-color);
  font-size: 13px;
}

.opportunity-pool-card {
  background: var(--background-white);
  border-radius: var(--border-radius-md);
  border: 1px solid rgba(95, 99, 104, 0.14);
  padding: var(--spacing-md);
}

.opportunity-pool-desc {
  display: block;
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
}

.opportunity-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.opportunity-item {
  border: 1px solid rgba(26, 115, 232, 0.12);
  border-radius: var(--border-radius-sm);
  padding: 8px 10px;
  background: #fbfdff;
}

.opportunity-university {
  display: inline-block;
  font-size: 12px;
  color: var(--primary-color);
  margin-bottom: 4px;
}

.opportunity-title {
  display: block;
  font-size: 13px;
  color: var(--text-primary);
  line-height: 1.4;
}

.opportunity-empty {
  display: block;
  font-size: 13px;
  color: var(--text-tertiary);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .urgent-card {
    min-width: 240px;
  }
  
  .countdown-number {
    font-size: 24px;
  }
  
  .greeting-text {
    font-size: 18px;
  }
  
  .section-title {
    font-size: 16px;
  }
}
