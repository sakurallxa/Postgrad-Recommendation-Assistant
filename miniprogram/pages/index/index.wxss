/* 首页样式 */

.container {
  padding: calc(var(--spacing-lg) + 2px) var(--spacing-lg) calc(var(--spacing-xl) + 10px);
  background-color: var(--surface-page);
  min-height: 100vh;
}

/* 问候区 */
.greeting-card {
  background: var(--surface-card-bg-soft);
  border: 1px solid rgba(26, 115, 232, 0.14);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-2);
}

.greeting-text {
  font-size: var(--font-size-hero);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
  display: block;
  line-height: var(--line-height-tight);
}

.stats-text {
  font-size: var(--font-size-body);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

/* 区块通用样式 */
.section {
  margin-bottom: calc(var(--spacing-xl) + 2px);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-header-vertical {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
}

.section-header-vertical .section-title {
  margin-bottom: var(--spacing-md);
}

.section-header-vertical .filter-bar {
  width: 100%;
}

.follow-entry-card {
  background: var(--surface-card-bg-soft);
  border: 1px solid var(--surface-card-border);
  border-radius: var(--border-radius-md);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-2);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.follow-entry-card:active {
  transform: translateY(-1px);
  box-shadow: var(--surface-card-shadow-active);
}

.follow-entry-summary {
  display: block;
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--grid-2);
  line-height: var(--line-height-normal);
}

.follow-entry-desc {
  font-size: var(--font-size-note);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.follow-entry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--grid-2);
  margin-top: var(--grid-1);
}

.follow-entry-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 28px;
  font-size: var(--font-size-caption);
  color: var(--primary-dark);
  background: rgba(26, 115, 232, 0.1);
  border: 1px solid rgba(26, 115, 232, 0.2);
  padding: 0 10px;
  border-radius: var(--border-radius-full);
  text-align: center;
}

.follow-entry-tag.more {
  color: var(--text-secondary);
  background: var(--background-white);
}

.follow-entry-tag-text {
  line-height: 1;
}

.section-title {
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--text-primary);
  line-height: var(--line-height-tight);
}

.section-subtext {
  font-size: var(--font-size-caption);
  color: var(--text-tertiary);
  margin-top: -6px;
  margin-bottom: var(--spacing-sm);
  line-height: var(--line-height-normal);
}

.section-more {
  font-size: var(--font-size-body);
  color: var(--primary-color);
  display: flex;
  align-items: center;
  margin-left: auto;
  flex-shrink: 0;
  white-space: nowrap;
  transition: opacity 0.2s ease;
}

.section-more:active {
  opacity: 0.75;
}

.arrow-right {
  margin-left: var(--spacing-xs);
  font-size: 12px;
}

/* 即将截止区 */
.urgent-camps {
  margin-top: var(--spacing-md);
}

.urgent-card {
  display: flex;
  align-items: center;
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  border-radius: var(--border-radius-md);
  box-shadow: var(--shadow-2);
  padding: var(--spacing-lg);
  width: 100%;
  margin-bottom: var(--spacing-md);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.urgent-card:active {
  transform: translateY(-1px);
  box-shadow: var(--surface-card-shadow-active);
}

.countdown {
  display: flex;
  align-items: baseline;
  margin-right: var(--spacing-md);
  min-width: 60px;
}

.countdown-number {
  font-size: 28px;
  font-weight: 700;
  line-height: 1;
}

.countdown-unit {
  font-size: var(--font-size-body);
  font-weight: 500;
  margin-left: var(--spacing-xs);
}

.countdown.urgent {
  color: var(--warning-color);
}

.countdown.expired {
  color: var(--error-color);
}

.countdown.normal {
  color: var(--success-color);
}

.urgent-info {
  flex: 1;
  min-width: 0;
}

.urgent-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: var(--spacing-sm);
}

.university-name {
  display: inline-flex;
  align-items: center;
  font-size: var(--font-size-caption);
  font-weight: 600;
  color: var(--primary-color);
  background: linear-gradient(135deg, var(--primary-light) 0%, rgba(74, 144, 226, 0.15) 100%);
  min-height: 22px;
  padding: 0 10px;
  line-height: 1.1;
  border-radius: var(--border-radius-sm);
  border: 1px solid rgba(74, 144, 226, 0.2);
}

.urgent-announcement-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-caption);
  font-weight: 600;
  height: 20px;
  padding: 0 7px;
  line-height: 1;
  border-radius: 4px;
  border: 1px solid transparent;
  letter-spacing: 0;
  flex-shrink: 0;
}

.urgent-announcement-badge text {
  line-height: 1;
}

.urgent-announcement-badge.summer-camp {
  color: #185abc;
  background: rgba(45, 108, 223, 0.08);
  border-color: rgba(45, 108, 223, 0.32);
}

.urgent-announcement-badge.pre-recommendation {
  color: #b05a00;
  background: rgba(255, 167, 38, 0.12);
  border-color: rgba(255, 167, 38, 0.35);
}

.camp-title {
  font-size: var(--font-size-body);
  font-weight: 400;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: var(--spacing-xs);
  line-height: var(--line-height-normal);
}

.deadline {
  font-size: var(--font-size-caption);
  color: var(--text-tertiary);
  display: block;
  line-height: var(--line-height-normal);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--spacing-sm);
}

.filter-row {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
}

.filter-label {
  flex-shrink: 0;
  font-size: var(--font-size-note);
  color: var(--text-secondary);
  line-height: 30px;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-item {
  display: inline-flex;
  font-size: var(--font-size-body);
  color: var(--text-secondary);
  padding: 6px 16px;
  border-radius: var(--border-radius-full);
  background-color: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(95, 99, 104, 0.24);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.2s ease;
  margin-right: var(--spacing-sm);
}

.filter-item.active {
  color: var(--primary-color);
  border-color: var(--primary-color);
  background-color: var(--surface-chip-bg);
  font-weight: 500;
}

/* 夏令营列表 */
.camp-list {
  margin-top: var(--spacing-md);
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
  color: var(--text-tertiary);
  font-size: var(--font-size-body);
}

.loading-text {
  margin-left: var(--spacing-sm);
}

.no-more {
  text-align: center;
  padding: var(--spacing-lg);
  color: var(--text-tertiary);
  font-size: var(--font-size-body);
}

.my-camps-empty {
  background: var(--surface-card-bg-soft);
  border-radius: var(--border-radius-md);
  border: 1px solid var(--surface-card-border);
  padding: var(--spacing-lg);
  text-align: center;
  box-shadow: var(--shadow-1);
}

.my-camps-empty-text {
  display: block;
  font-size: var(--font-size-body);
  color: var(--text-secondary);
  line-height: var(--line-height-normal);
}

.my-camps-empty-action {
  margin-top: var(--spacing-sm);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6px 14px;
  border-radius: var(--border-radius-full);
  color: var(--primary-color);
  border: 1px solid var(--primary-color);
  font-size: var(--font-size-note);
}

.opportunity-pool-card {
  background: linear-gradient(160deg, #ffffff 0%, #f6f9ff 100%);
  border-radius: var(--border-radius-lg);
  border: 1px solid rgba(26, 115, 232, 0.18);
  padding: var(--spacing-lg);
  box-shadow: 0 8px 22px rgba(26, 115, 232, 0.1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.opportunity-pool-card:active {
  transform: translateY(-1px);
  box-shadow: 0 12px 28px rgba(26, 115, 232, 0.14);
}

.opportunity-pool-desc {
  display: block;
  font-size: var(--font-size-note);
  color: #4f5661;
  margin-bottom: var(--spacing-md);
  line-height: var(--line-height-relaxed);
}

.opportunity-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.opportunity-item {
  border: 1px solid rgba(26, 115, 232, 0.16);
  border-radius: var(--border-radius-md);
  padding: 12px;
  background: rgba(255, 255, 255, 0.96);
}

.opportunity-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 6px;
}

.opportunity-university {
  display: inline-flex;
  align-items: center;
  font-size: var(--font-size-caption);
  font-weight: 600;
  color: #1a5fc4;
  background: rgba(26, 115, 232, 0.1);
  border: 1px solid rgba(26, 115, 232, 0.2);
  border-radius: 12px;
  padding: 2px 8px;
}

.opportunity-type-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-caption);
  font-weight: 600;
  min-height: 20px;
  padding: 0 8px;
  border-radius: 10px;
  border: 1px solid transparent;
}

.opportunity-type-badge.summer-camp {
  color: #185abc;
  background: rgba(45, 108, 223, 0.08);
  border-color: rgba(45, 108, 223, 0.25);
}

.opportunity-type-badge.pre-recommendation {
  color: #b05a00;
  background: rgba(255, 167, 38, 0.12);
  border-color: rgba(255, 167, 38, 0.35);
}

.opportunity-title {
  display: block;
  font-size: var(--font-size-body);
  font-weight: 500;
  color: var(--text-primary);
  line-height: var(--line-height-normal);
}

.opportunity-deadline {
  display: block;
  margin-top: 6px;
  font-size: var(--font-size-caption);
  color: var(--text-tertiary);
  line-height: var(--line-height-normal);
}

.opportunity-empty {
  display: block;
  font-size: var(--font-size-note);
  color: var(--text-tertiary);
  line-height: var(--line-height-normal);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .urgent-card {
    min-width: 240px;
  }
  
  .countdown-number {
    font-size: 24px;
  }
  
  .greeting-text {
    font-size: 18px;
  }
  
  .section-title {
    font-size: 16px;
  }
}
