/* 首页样式 */

.container {
  padding: var(--spacing-lg);
  background-color: var(--background-light);
  min-height: 100vh;
}

/* 问候区 */
.greeting-card {
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--background-white) 100%);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-1);
}

.greeting-text {
  font-size: 20px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
  display: block;
}

.stats-text {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 区块通用样式 */
.section {
  margin-bottom: var(--spacing-xl);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-header-vertical {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
}

.section-header-vertical .section-title {
  margin-bottom: var(--spacing-md);
}

.section-header-vertical .filter-bar {
  width: 100%;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 14px;
  color: var(--primary-color);
  display: flex;
  align-items: center;
  margin-left: auto;
}

.arrow-right {
  margin-left: var(--spacing-xs);
  font-size: 12px;
}

/* 即将截止区 */
.urgent-camps {
  margin-top: var(--spacing-md);
}

.urgent-scroll {
  display: flex;
  padding: var(--spacing-md) var(--spacing-xs);
  gap: var(--spacing-lg);
}

.urgent-card {
  display: flex;
  align-items: center;
  background-color: var(--background-white);
  border-radius: var(--border-radius-md);
  box-shadow: var(--shadow-2);
  padding: var(--spacing-lg);
  min-width: 280px;
  flex-shrink: 0;
  margin-bottom: var(--spacing-sm);
}

.countdown {
  display: flex;
  align-items: baseline;
  margin-right: var(--spacing-md);
  min-width: 60px;
}

.countdown-number {
  font-size: 28px;
  font-weight: 700;
  line-height: 1;
}

.countdown-unit {
  font-size: 14px;
  font-weight: 500;
  margin-left: var(--spacing-xs);
}

.countdown.urgent {
  color: var(--warning-color);
}

.countdown.expired {
  color: var(--error-color);
}

.countdown.normal {
  color: var(--success-color);
}

.urgent-info {
  flex: 1;
  min-width: 0;
}

.university-name {
  display: inline-block;
  font-size: 12px;
  font-weight: 600;
  color: var(--primary-color);
  background: linear-gradient(135deg, var(--primary-light) 0%, rgba(74, 144, 226, 0.15) 100%);
  padding: 4px 10px;
  border-radius: var(--border-radius-sm);
  margin-bottom: var(--spacing-sm);
  border: 1px solid rgba(74, 144, 226, 0.2);
}

.camp-title {
  font-size: 14px;
  font-weight: 400;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: var(--spacing-xs);
  line-height: 1.4;
}

.deadline {
  font-size: 12px;
  color: var(--text-tertiary);
  display: block;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--spacing-sm);
}

.filter-row {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
}

.filter-label {
  flex-shrink: 0;
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 30px;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-item {
  display: inline-flex;
  font-size: 14px;
  color: var(--text-secondary);
  padding: 6px 16px;
  border-radius: var(--border-radius-full);
  background-color: var(--background-white);
  border: 1px solid var(--border-color);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.2s ease;
  margin-right: var(--spacing-sm);
}

.filter-item.active {
  color: var(--primary-color);
  border-color: var(--primary-color);
  background-color: var(--primary-light);
  font-weight: 500;
}

.filter-btn {
  font-size: 14px;
  color: var(--primary-color);
  padding: 6px 12px;
  display: flex;
  align-items: center;
  white-space: nowrap;
  margin-left: auto;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
}

/* 夏令营列表 */
.camp-list {
  margin-top: var(--spacing-md);
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
  color: var(--text-tertiary);
  font-size: 14px;
}

.loading-text {
  margin-left: var(--spacing-sm);
}

.no-more {
  text-align: center;
  padding: var(--spacing-lg);
  color: var(--text-tertiary);
  font-size: 14px;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .urgent-card {
    min-width: 240px;
  }
  
  .countdown-number {
    font-size: 24px;
  }
  
  .greeting-text {
    font-size: 18px;
  }
  
  .section-title {
    font-size: 16px;
  }
}
