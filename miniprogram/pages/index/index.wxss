/* 首页 - v0.2 重构 - 清爽呼吸感设计 */

.page {
  padding: var(--space-4) var(--space-3) calc(env(safe-area-inset-bottom) + var(--space-5));
  min-height: 100vh;
  box-sizing: border-box;
}

/* ========== Hero ========== */
.hero {
  padding: var(--space-2) var(--space-2) var(--space-4);
}
.hero-title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  line-height: var(--leading-tight);
  margin-bottom: var(--space-2);
}
.hero-subtitle {
  font-size: var(--text-base);
  color: var(--text-secondary);
  line-height: var(--leading-normal);
}

/* ========== Stats ========== */
.stats-row {
  display: flex;
  background: var(--bg-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4) 0;
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-sm);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
}
.stat-value {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  line-height: 1;
}
.stat-value-success { color: var(--color-success); }
.stat-value-primary { color: var(--color-primary); }
.stat-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}
.stat-divider {
  width: 1rpx;
  background: var(--border-light);
  margin: 0 var(--space-2);
}

/* ========== Onboarding Card ========== */
.onboarding-card {
  background: var(--bg-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-sm);
}
.onboarding-step {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: var(--space-3) 0;
  border-bottom: 1rpx solid var(--border-light);
}
.onboarding-step:last-child { border-bottom: none; padding-bottom: 0; }
.onboarding-step:first-child { padding-top: 0; }
.onboarding-step.completed {
  opacity: 0.7;
}
.onboarding-icon-wrap {
  margin-bottom: var(--space-1);
}
.onboarding-icon { font-size: 40rpx; }
.onboarding-check {
  display: inline-flex;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: var(--color-success);
  color: #FFFFFF;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: var(--weight-bold);
}
.onboarding-step-title {
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  margin-bottom: 6rpx;
}
.onboarding-step-desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}
.onboarding-btn {
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: var(--text-sm);
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-md);
  border: none;
  line-height: 1.4;
}
.onboarding-btn::after { border: none; }

/* ========== Submit URL Card ========== */
.submit-url-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #F5F3FF 0%, #EEF2FF 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-4);
  border: 2rpx solid rgba(79, 70, 229, 0.15);
}
.submit-url-icon {
  font-size: 48rpx;
  margin-right: var(--space-3);
}
.submit-url-text { flex: 1; }
.submit-url-title {
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.submit-url-desc {
  font-size: var(--text-xs);
  color: var(--text-secondary);
}
.submit-url-arrow {
  font-size: 40rpx;
  color: var(--color-primary);
  font-weight: 200;
}

/* ========== Tab Bar ========== */
.tab-bar {
  display: flex;
  background: var(--bg-surface);
  border-radius: var(--radius-pill);
  padding: 6rpx;
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-xs);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--space-2);
  font-size: var(--text-sm);
  color: var(--text-secondary);
  border-radius: var(--radius-pill);
}
.tab-item.active {
  background: var(--color-primary);
  color: #FFFFFF;
  font-weight: var(--weight-medium);
}

/* ========== Match Card ========== */
.match-list { display: flex; flex-direction: column; gap: var(--space-3); }

.match-card {
  background: var(--bg-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  box-shadow: var(--shadow-sm);
}
.match-card:active {
  background: var(--bg-muted);
}

.match-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}
.match-recommendation {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: var(--text-xs);
  font-weight: var(--weight-medium);
}
.match-recommendation-success { background: var(--color-success-soft); color: var(--color-success); }
.match-recommendation-warning { background: var(--color-warning-soft); color: #B45309; }
.match-recommendation-skip    { background: var(--bg-muted); color: var(--text-tertiary); }

.match-score {
  display: inline-flex;
  align-items: baseline;
  color: var(--text-primary);
}
.match-score-value {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
}
.match-score-unit {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-left: 2rpx;
}

.match-affil {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-1);
}
.match-univ { color: var(--color-primary); font-weight: var(--weight-medium); }
.match-dept { margin-left: 4rpx; }

.match-title {
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  line-height: var(--leading-tight);
  margin-bottom: var(--space-2);
}

.match-summary {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: var(--leading-normal);
  background: var(--bg-page);
  padding: var(--space-2);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-3);
  border-left: 4rpx solid var(--color-primary);
}

.req-list {
  margin-bottom: var(--space-3);
}
.req-item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: 6rpx 0;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}
.req-icon {
  flex-shrink: 0;
  width: 32rpx;
  text-align: center;
  font-weight: var(--weight-bold);
}
.req-icon-pass    { color: var(--color-success); }
.req-icon-warn    { color: var(--color-warning); }
.req-icon-fail    { color: var(--color-danger); }
.req-icon-unknown { color: var(--text-tertiary); }
.req-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.req-more {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  padding-left: calc(32rpx + var(--space-2));
  margin-top: 4rpx;
}

.match-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-2);
  border-top: 1rpx solid var(--border-light);
}
.match-deadline {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--text-xs);
  color: var(--text-secondary);
}
.match-deadline-icon { color: var(--color-warning); }

.match-actions {
  display: flex;
  gap: var(--space-2);
}
.match-action-btn {
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-pill);
  font-size: var(--text-xs);
  color: var(--text-secondary);
  background: var(--bg-muted);
}
.match-action-btn:active { background: var(--border-default); }
.match-action-primary {
  background: var(--color-primary);
  color: #FFFFFF;
}
.match-action-primary:active { background: var(--color-primary-hover); }

/* Skeleton */
.skeleton-card {
  height: 280rpx;
  margin-bottom: var(--space-3);
}
.loading-state {
  display: flex;
  flex-direction: column;
}

/* 空状态优化 */
.empty-state-text {
  font-size: var(--text-md);
  color: var(--text-primary);
  margin-bottom: 8rpx;
  font-weight: var(--weight-medium);
}
.empty-state-sub {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-bottom: var(--space-3);
  padding: 0 var(--space-3);
}
.empty-state-action {
  margin-top: var(--space-2);
  padding: var(--space-2) var(--space-3);
  background: var(--color-primary-soft);
  color: var(--color-primary);
  border-radius: var(--radius-pill);
  font-size: var(--text-sm);
}
