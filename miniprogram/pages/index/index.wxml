<view class="container">
  <!-- 问候区 -->
  <view class="greeting-card">
    <text class="greeting-text">你好，保研er 👋</text>
    <text class="stats-text">
      已关注 {{stats.universityCount}} 所院校 · {{stats.campCount}} 个夏令营/预推免 · {{stats.reminderCount}} 个提醒
    </text>
  </view>

  <!-- 即将截止提醒区 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">即将截止</text>
      <navigator url="/packageCamp/pages/camp-list/index?mode=urgent" class="section-more">
        查看全部
        <text class="arrow-right">→</text>
      </navigator>
    </view>
    
    <view wx:if="{{urgentCamps.length > 0}}" class="urgent-camps">
      <view
        wx:for="{{urgentCamps}}"
        wx:key="id"
        class="urgent-card"
        bindtap="handleUrgentCampTap"
        data-id="{{item.id}}"
        data-announcement-type="{{item.announcementType}}"
        data-title="{{item.title}}"
      >
        <view class="countdown {{item.statusClass}}">
          <text class="countdown-number">{{item.daysRemaining}}</text>
          <text class="countdown-unit">天</text>
        </view>
        <view class="urgent-info">
          <view class="urgent-meta">
            <text class="university-name">{{item.universityName}}</text>
            <view class="urgent-announcement-badge {{item.announcementType === 'pre_recommendation' ? 'pre-recommendation' : 'summer-camp'}}">
              <text>{{item.announcementType === 'pre_recommendation' ? '预推免' : '夏令营'}}</text>
            </view>
          </view>
          <text class="camp-title">{{item.title}}</text>
          <text class="deadline">{{item.deadlineText}}</text>
        </view>
      </view>
    </view>
    
    <empty-state wx:else text="暂无即将截止的夏令营/预推免" />
  </view>

  <!-- 院校关注入口 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">院校关注</text>
      <view class="section-more" bindtap="handleOpenSelector">
        <text>{{stats.universityCount > 0 ? '管理关注' : '去选择'}}</text>
        <text class="arrow-right">→</text>
      </view>
    </view>
    <view class="follow-entry-card" bindtap="handleOpenSelector">
      <text wx:if="{{stats.universityCount === 0}}" class="follow-entry-summary">暂未关注院校</text>
      <text wx:if="{{stats.universityCount === 0}}" class="follow-entry-desc">
        先选择关注院校，系统会自动聚合对应夏令营/预推免信息。
      </text>
      <view wx:else>
        <text class="follow-entry-summary">已关注 {{stats.universityCount}} 所院校</text>
      </view>
      <view wx:if="{{stats.universityCount > 0}}" class="follow-entry-tags">
        <view
          wx:for="{{followedUniversitiesPreview}}"
          wx:key="*this"
          class="follow-entry-tag"
        >
          <text class="follow-entry-tag-text">{{item}}</text>
        </view>
        <view wx:if="{{followedUniversitiesOverflow > 0}}" class="follow-entry-tag more">
          <text class="follow-entry-tag-text">+{{followedUniversitiesOverflow}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 夏令营列表区 -->
  <view class="section">
    <view class="section-header-vertical">
      <text class="section-title">我的保研</text>
      <text class="section-subtext">仅展示你已关注院校的结果</text>
      <view class="filter-bar">
        <view class="filter-row">
          <text class="filter-label">状态</text>
          <scroll-view scroll-x enable-flex="true" class="filter-scroll">
            <view
              wx:for="{{statusFilterOptions}}"
              wx:key="value"
              class="filter-item {{activeStatusFilter === item.value ? 'active' : ''}}"
              bindtap="handleFilterChange"
              data-value="{{item.value}}"
            >
              {{item.label}}
            </view>
          </scroll-view>
        </view>
        <view class="filter-row">
          <text class="filter-label">年份</text>
          <scroll-view scroll-x enable-flex="true" class="filter-scroll">
            <view
              wx:for="{{yearFilterOptions}}"
              wx:key="value"
              class="filter-item {{activeYearFilter === item.value ? 'active' : ''}}"
              bindtap="handleYearFilterChange"
              data-value="{{item.value}}"
            >
              {{item.label}}
            </view>
          </scroll-view>
        </view>
        <view class="filter-row">
          <text class="filter-label">院校</text>
          <scroll-view scroll-x enable-flex="true" class="filter-scroll">
            <view
              wx:for="{{universityFilterOptions}}"
              wx:key="value"
              class="filter-item {{activeUniversityFilter === item.value ? 'active' : ''}}"
              bindtap="handleUniversityFilterChange"
              data-value="{{item.value}}"
            >
              {{item.label}}
            </view>
          </scroll-view>
        </view>
      </view>
    </view>
    
    <view wx:if="{{campList.length > 0}}" class="camp-list">
      <camp-card 
        wx:for="{{campList}}" 
        wx:key="id"
        wx:if="{{item}}"
        camp="{{item}}"
        bindtap="handleCampTap"
        bindremind="handleRemindTap"
        data-id="{{item.id}}"
        data-announcement-type="{{item.announcementType}}"
        data-title="{{item.title}}"
      />
      
      <!-- 加载更多 -->
      <view wx:if="{{loadingMore}}" class="loading-more">
        <view class="loading"></view>
        <text class="loading-text">加载中...</text>
      </view>
      
      <view wx:else-if="{{!hasMore}}" class="no-more">
        <text>没有更多了</text>
      </view>
    </view>
    
    <view wx:else class="my-camps-empty">
      <text class="my-camps-empty-text">{{myCampsEmptyText}}</text>
      <view wx:if="{{stats.universityCount === 0}}" class="my-camps-empty-action" bindtap="handleOpenSelector">
        去关注目标院校
      </view>
    </view>
  </view>

  <!-- 夏令营机会池 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">保研机会池</text>
      <view class="section-more" bindtap="handleOpenOpportunityPool">
        <text>查看全部</text>
        <text class="arrow-right">→</text>
      </view>
    </view>
    <view class="opportunity-pool-card">
      <text class="opportunity-pool-desc">汇总全网夏令营/预推免信息，避免错过其他机会</text>
      <view wx:if="{{opportunityPoolCamps.length > 0}}" class="opportunity-list">
        <navigator
          wx:for="{{opportunityPoolCamps}}"
          wx:key="id"
          class="opportunity-item"
          url="{{item.detailUrl}}"
        >
          <view class="opportunity-meta">
            <text class="opportunity-university">{{item.universityName}}</text>
            <view class="opportunity-type-badge {{item.announcementType === 'pre_recommendation' ? 'pre-recommendation' : 'summer-camp'}}">
              <text>{{item.announcementType === 'pre_recommendation' ? '预推免' : '夏令营'}}</text>
            </view>
          </view>
          <text class="opportunity-title">{{item.title}}</text>
          <text wx:if="{{item.deadline}}" class="opportunity-deadline">{{item.deadline}} 截止</text>
        </navigator>
      </view>
      <text wx:else class="opportunity-empty">暂未发现新的公开机会</text>
    </view>
  </view>
</view>
