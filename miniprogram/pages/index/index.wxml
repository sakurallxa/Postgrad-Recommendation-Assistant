<view class="page">
  <!-- 顶部欢迎 -->
  <view class="hero">
    <view class="hero-title">你好，保研er 👋</view>
    <view class="hero-subtitle">
      <text wx:if="{{!hasSubscription}}">先选 3-5 所目标校，我来帮你盯紧新机会</text>
      <text wx:elif="{{stats.recommendCount > 0}}">为你筛出 {{stats.recommendCount}} 个高匹配机会</text>
      <text wx:else>暂时还没有新机会，提交一个公告 URL 试试 AI 助理？</text>
    </view>
  </view>

  <!-- 概览数据条 -->
  <view class="stats-row" wx:if="{{hasSubscription}}">
    <view class="stat-item" bindtap="onTapStat" data-action="undecided">
      <view class="stat-value">{{stats.undecidedCount}}</view>
      <view class="stat-label">待决策</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onTapStat" data-action="interested">
      <view class="stat-value stat-value-success">{{stats.interestedCount}}</view>
      <view class="stat-label">感兴趣</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onTapStat" data-action="applied">
      <view class="stat-value stat-value-primary">{{stats.appliedCount}}</view>
      <view class="stat-label">已申请</view>
    </view>
  </view>

  <!-- 引导：未订阅院系 -->
  <view wx:if="{{!hasSubscription}}" class="onboarding-card">
    <view class="onboarding-step">
      <view class="onboarding-icon">🎯</view>
      <view class="onboarding-step-title">第 1 步 · 填写档案</view>
      <view class="onboarding-step-desc">告诉 AI 你的 GPA、专业、目标方向</view>
      <button class="onboarding-btn" bindtap="goProfile">填写档案</button>
    </view>
    <view class="onboarding-step">
      <view class="onboarding-icon">🏫</view>
      <view class="onboarding-step-title">第 2 步 · 选择目标校</view>
      <view class="onboarding-step-desc">5 所重点校 × 你专业相关的院系</view>
      <button class="onboarding-btn" bindtap="goSelector">选择院系</button>
    </view>
    <view class="onboarding-step">
      <view class="onboarding-icon">✨</view>
      <view class="onboarding-step-title">第 3 步 · 享受智能筛选</view>
      <view class="onboarding-step-desc">AI 每天扫一遍，匹配你才推送</view>
    </view>
  </view>

  <!-- 提交URL测试入口（始终显示，灰度阶段） -->
  <view class="submit-url-card" bindtap="goSubmitUrl">
    <view class="submit-url-icon">🔗</view>
    <view class="submit-url-text">
      <view class="submit-url-title">手动测试 AI 助理</view>
      <view class="submit-url-desc">贴一条公告 URL，看 AI 给出的匹配判断</view>
    </view>
    <view class="submit-url-arrow">›</view>
  </view>

  <!-- 列表 Tab 切换 -->
  <view class="tab-bar" wx:if="{{hasSubscription || opportunities.length > 0}}">
    <view
      class="tab-item {{activeTab === 'undecided' ? 'active' : ''}}"
      data-tab="undecided"
      bindtap="onSwitchTab"
    >今日新机会</view>
    <view
      class="tab-item {{activeTab === 'interested' ? 'active' : ''}}"
      data-tab="interested"
      bindtap="onSwitchTab"
    >已收藏</view>
  </view>

  <!-- 机会卡片列表 -->
  <view class="match-list" wx:if="{{opportunities.length > 0}}">
    <view
      class="match-card"
      wx:for="{{opportunities}}"
      wx:key="id"
      bindtap="onTapMatch"
      data-id="{{item.id}}"
    >
      <!-- 顶部：推荐标签 + 学校 -->
      <view class="match-head">
        <view class="match-recommendation {{item.recommendationClass}}">
          <text class="match-recommendation-icon">{{item.recommendationIcon}}</text>
          <text class="match-recommendation-text">{{item.recommendationText}}</text>
        </view>
        <view class="match-score" wx:if="{{item.matchScore != null}}">
          <text class="match-score-value">{{item.matchScore}}</text>
          <text class="match-score-unit">%</text>
        </view>
      </view>

      <!-- 学校院系 -->
      <view class="match-affil">
        <text class="match-univ">{{item.camp.universityName}}</text>
        <text wx:if="{{item.camp.departmentName}}" class="match-dept">· {{item.camp.departmentName}}</text>
      </view>

      <!-- 标题 -->
      <view class="match-title">{{item.camp.title}}</view>

      <!-- AI 摘要 -->
      <view class="match-summary" wx:if="{{item.extractedSummary}}">{{item.extractedSummary}}</view>

      <!-- 关键要求（前2-3条） -->
      <view class="req-list" wx:if="{{item.keyRequirementsPreview.length > 0}}">
        <view
          class="req-item"
          wx:for="{{item.keyRequirementsPreview}}"
          wx:for-item="req"
          wx:key="index"
        >
          <text class="req-icon req-icon-{{req.userMatch}}">{{req.icon}}</text>
          <text class="req-text">{{req.requirement}}</text>
        </view>
        <view wx:if="{{item.keyRequirementsMore > 0}}" class="req-more">
          还有 {{item.keyRequirementsMore}} 项 ›
        </view>
      </view>

      <!-- 底部：截止 + 操作 -->
      <view class="match-foot">
        <view class="match-deadline" wx:if="{{item.deadlineText}}">
          <text class="match-deadline-icon">⏰</text>
          <text class="match-deadline-text">{{item.deadlineText}}</text>
        </view>
        <view class="match-actions" catchtap="noop">
          <view class="match-action-btn" data-id="{{item.id}}" bindtap="onActionSkip">跳过</view>
          <view class="match-action-btn match-action-primary" data-id="{{item.id}}" bindtap="onActionInterested">
            <text wx:if="{{item.userAction !== 'interested'}}">感兴趣</text>
            <text wx:else>已收藏</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{hasSubscription && !loading}}" class="empty-state">
    <view class="empty-state-icon">✨</view>
    <view class="empty-state-text">{{emptyStateText}}</view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="skeleton skeleton-card"></view>
    <view class="skeleton skeleton-card"></view>
  </view>
</view>
