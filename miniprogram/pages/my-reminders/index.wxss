/* 我的提醒 - 行动驾驶舱 */
.reminders-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 12px 16px 20px;
  box-sizing: border-box;
}

.summary-card {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

.summary-item {
  flex: 1;
  border-radius: 12px;
  padding: 10px 8px;
  border: 1px solid #e4e8f0;
  background: #ffffff;
  text-align: center;
}

.summary-item.urgent {
  background: #eef5ff;
}

.summary-item.recent {
  background: #f4f8ff;
}

.summary-item.changed {
  background: #fff5f2;
  border-color: #ffd7cc;
}

.summary-value {
  display: block;
  font-size: 20px;
  line-height: 1.2;
  font-weight: 700;
  color: #1a73e8;
}

.summary-item.changed .summary-value {
  color: #ea4335;
}

.summary-title {
  display: block;
  margin-top: 3px;
  font-size: 12px;
  color: #3c4043;
}

.summary-desc {
  display: block;
  margin-top: 2px;
  font-size: 11px;
  color: #80868b;
}

.control-card {
  background: #ffffff;
  border-radius: 12px;
  padding: 12px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  margin-bottom: 14px;
}

.view-mode-switch {
  display: flex;
  background: #f3f5f7;
  border-radius: 10px;
  padding: 2px;
  margin-bottom: 12px;
}

.view-mode-item {
  flex: 1;
  height: 32px;
  line-height: 32px;
  text-align: center;
  border-radius: 8px;
  font-size: 13px;
  color: #5f6368;
}

.view-mode-item.active {
  background: #ffffff;
  color: #1a73e8;
  font-weight: 600;
}

.focus-filter-title {
  font-size: 12px;
  font-weight: 600;
  color: #5f6368;
  margin-bottom: 8px;
}

.focus-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.focus-filter-item {
  border: 1px solid #dadce0;
  border-radius: 16px;
  padding: 5px 12px;
  font-size: 12px;
  color: #5f6368;
  background: #ffffff;
}

.focus-filter-item.active {
  border-color: #1a73e8;
  background: #e8f0fe;
  color: #1a73e8;
}

.focus-filter-hint {
  display: block;
  margin-top: 8px;
  font-size: 11px;
  color: #80868b;
}

.school-card,
.task-card {
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.school-card {
  margin-bottom: 12px;
  padding: 12px;
}

.school-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.school-name {
  font-size: 16px;
  color: #202124;
  font-weight: 600;
}

.school-count {
  font-size: 12px;
  color: #1a73e8;
  background: #e8f0fe;
  border-radius: 10px;
  padding: 2px 8px;
}

.school-scope-switch {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
}

.school-scope-item {
  border: 1px solid #dadce0;
  border-radius: 14px;
  padding: 4px 9px;
  font-size: 11px;
  line-height: 1.4;
  color: #5f6368;
  background: #ffffff;
}

.school-scope-item.active {
  border-color: #1a73e8;
  background: #e8f0fe;
  color: #1a73e8;
}

.school-scope-item.active.urgent {
  border-color: #d93025;
  background: #fce8e6;
  color: #d93025;
}

.school-scope-item.active.recent {
  border-color: #1a73e8;
  background: #e8f0fe;
  color: #1a73e8;
}

.school-scope-item.active.changed {
  border-color: #f6b26b;
  background: #fff4e5;
  color: #b06000;
}

.school-pending-list {
  margin-top: 10px;
}

.school-task-item {
  border: 1px solid #edf0f3;
  border-radius: 10px;
  background: #fafbfc;
  padding: 9px 10px;
  margin-bottom: 8px;
}

.school-task-item:last-child {
  margin-bottom: 0;
}

.school-task-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}

.school-task-title {
  display: block;
  font-size: 13px;
  color: #202124;
  line-height: 1.4;
  flex: 1;
}

.school-task-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 5px;
}

.preview-deadline {
  font-size: 12px;
  color: #5f6368;
}

.preview-deadline.today {
  color: #d93025;
  font-weight: 600;
}

.preview-deadline.three_days {
  color: #1a73e8;
}

.preview-change {
  font-size: 11px;
  color: #b06000;
  background: #fff4e5;
  border-radius: 10px;
  padding: 2px 8px;
}

.school-task-reminder {
  display: block;
  margin-top: 5px;
  font-size: 12px;
  color: #1a73e8;
}

.school-task-text-actions {
  display: flex;
  align-items: center;
  margin-top: 6px;
}

.text-action {
  font-size: 13px;
  line-height: 1.2;
  padding: 2px 0;
}

.text-action.secondary {
  color: #1a73e8;
}

.text-action.primary {
  color: #1370e8;
  font-weight: 600;
}

.text-action.warning {
  color: #b06000;
  font-weight: 600;
}

.text-action-divider {
  width: 1px;
  height: 14px;
  margin: 0 10px;
  background: #c7ccd1;
  align-self: center;
}

.school-expand-hint {
  margin-top: 8px;
  padding: 8px;
  text-align: center;
  border-radius: 8px;
  color: #1a73e8;
  font-size: 12px;
  background: #edf4ff;
}

.school-expand-hint.collapse {
  background: #f1f3f4;
  color: #5f6368;
}

.school-empty-inline {
  margin-top: 10px;
  border-radius: 10px;
  background: #f8f9fa;
  padding: 10px;
  color: #80868b;
  font-size: 12px;
  text-align: center;
}

.task-section {
  margin-bottom: 14px;
}

.task-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  padding: 0 2px;
}

.task-section-title {
  font-size: 14px;
  color: #202124;
  font-weight: 600;
}

.task-section-count {
  font-size: 12px;
  color: #80868b;
}

.task-card {
  padding: 12px;
  margin-bottom: 10px;
}

.task-card:last-child {
  margin-bottom: 0;
}

.task-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.task-school {
  font-size: 12px;
  color: #1a73e8;
  background: #e8f0fe;
  border: 1px solid rgba(26, 115, 232, 0.2);
  border-radius: 8px;
  padding: 2px 8px;
}

.task-tag {
  font-size: 11px;
  border-radius: 10px;
  padding: 2px 8px;
}

.task-tag.urgent {
  color: #d93025;
  background: #fce8e6;
}

.task-tag.recent {
  color: #1a73e8;
  background: #e8f0fe;
}

.task-tag.changed {
  color: #b06000;
  background: #fff4e5;
}

.task-tag.later {
  color: #5f6368;
  background: #f1f3f4;
}

.task-tag.handled {
  color: #137333;
  background: #e6f4ea;
}

.task-title {
  display: block;
  font-size: 16px;
  color: #202124;
  line-height: 1.45;
  font-weight: 600;
}

.task-deadline {
  display: block;
  margin-top: 5px;
  font-size: 13px;
  color: #5f6368;
}

.task-deadline.today {
  color: #d93025;
  font-weight: 600;
}

.task-deadline.three_days {
  color: #1a73e8;
}

.task-info {
  margin-top: 10px;
  border: 1px solid #edf0f3;
  border-radius: 10px;
  background: #fafbfc;
  padding: 8px 10px;
}

.task-info-row {
  display: flex;
  margin-bottom: 6px;
}

.task-info-row:last-child {
  margin-bottom: 0;
}

.task-info-label {
  width: 88px;
  flex-shrink: 0;
  font-size: 12px;
  color: #80868b;
}

.task-info-value {
  font-size: 13px;
  color: #3c4043;
  flex: 1;
}

.task-reminder-hint {
  margin-top: 9px;
  border-left: 3px solid #d2e3fc;
  padding-left: 8px;
}

.task-reminder-hint-label {
  display: block;
  font-size: 11px;
  color: #80868b;
}

.task-reminder-hint-value {
  display: block;
  margin-top: 2px;
  font-size: 12px;
  color: #1a73e8;
}

.task-change-block {
  margin-top: 10px;
  border: 1px solid #ffe0b2;
  background: #fff8ee;
  border-radius: 10px;
  padding: 8px 10px;
}

.task-change-title {
  display: block;
  font-size: 11px;
  color: #b06000;
}

.task-change-summary {
  display: block;
  margin-top: 3px;
  font-size: 12px;
  color: #7a4b00;
  line-height: 1.5;
}

.task-attention-block {
  margin-top: 10px;
  border: 1px solid #f8d7da;
  background: #fff5f6;
  border-radius: 10px;
  padding: 8px 10px;
}

.task-attention-title {
  display: block;
  font-size: 11px;
  color: #d93025;
}

.task-attention-item {
  display: block;
  margin-top: 3px;
  font-size: 12px;
  color: #b3261e;
  line-height: 1.5;
}

.task-actions {
  display: flex;
  gap: 8px;
  margin-top: 12px;
  padding-top: 10px;
  border-top: 1px solid #f0f0f0;
}

.action-btn {
  flex: 1;
  font-size: 13px;
  border-radius: 8px;
}

.action-btn.secondary {
  color: #1a73e8;
  border: 1px solid #1a73e8;
  background: #ffffff;
}

.action-btn.primary {
  color: #ffffff;
  border: 1px solid #1a73e8;
  background: #1a73e8;
}

.action-btn.warning {
  color: #b06000;
  border: 1px solid #f6b26b;
  background: #fff4e5;
}

.action-btn::after {
  border: none;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
  text-align: center;
}

.empty-text {
  font-size: 16px;
  color: #5f6368;
  margin-bottom: 8px;
}

.empty-subtext {
  font-size: 13px;
  color: #80868b;
}
