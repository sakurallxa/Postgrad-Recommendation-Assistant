/* 我的提醒页样式 */
.reminders-page {
  min-height: 100vh;
  background-color: #F8F9FA;
}

/* 筛选栏 */
.filter-section {
  background-color: #FFFFFF;
  padding: 12px 16px;
  border-bottom: 1px solid #DADCE0;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.filter-tag {
  padding: 6px 16px;
  border: 1px solid #DADCE0;
  border-radius: 16px;
  font-size: 14px;
  color: #5F6368;
  background-color: #FFFFFF;
}

.filter-tag.active {
  background-color: #E8F0FE;
  border-color: #1A73E8;
  color: #1A73E8;
}

/* 提醒列表 */
.reminder-list-section {
  padding: 12px 16px;
}

.reminder-item {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.camp-title {
  flex: 1;
  font-size: 16px;
  font-weight: 500;
  color: #202124;
  margin-right: 12px;
  line-height: 1.4;
}

.reminder-status {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
}

.reminder-status.pending {
  background-color: #E8F0FE;
  color: #1A73E8;
}

.reminder-status.sent {
  background-color: #E6F4EA;
  color: #34A853;
}

.reminder-status.expired {
  background-color: #FCE8E6;
  color: #EA4335;
}

.reminder-info {
  margin-bottom: 12px;
}

.university-tag {
  display: inline-block;
  font-size: 13px;
  font-weight: 600;
  color: #1A73E8;
  background: linear-gradient(135deg, #E8F0FE 0%, rgba(26, 115, 232, 0.12) 100%);
  padding: 6px 14px;
  border-radius: 8px;
  margin-bottom: 12px;
  border: 1px solid rgba(26, 115, 232, 0.2);
  box-shadow: 0 1px 2px rgba(26, 115, 232, 0.08);
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  margin-right: 8px;
}

.info-text {
  font-size: 14px;
  color: #5F6368;
  flex: 1;
}

.reminder-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding-top: 12px;
  border-top: 1px solid #F0F0F0;
}

.action-btn {
  font-size: 14px;
  padding: 6px 12px;
  border-radius: 8px;
  min-width: 80px;
}

.action-btn.secondary {
  background-color: #FFFFFF;
  color: #1A73E8;
  border: 1px solid #1A73E8;
}

.action-btn.danger {
  background-color: #FFFFFF;
  color: #EA4335;
  border: 1px solid #EA4335;
}

.action-btn::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 0;
  text-align: center;
}

.empty-text {
  font-size: 16px;
  color: #5F6368;
  margin-top: 16px;
  margin-bottom: 8px;
}

.empty-subtext {
  font-size: 14px;
  color: #80868B;
}
