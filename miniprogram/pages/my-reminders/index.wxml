<view class="reminders-page">
  <view class="center-switch">
    <view
      wx:for="{{centerTabs}}"
      wx:key="value"
      class="center-switch-item {{activeCenterTab === item.value ? 'active' : ''}}"
      bindtap="onCenterTabTap"
      data-value="{{item.value}}"
    >
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{activeCenterTab === 'risk'}}">
  <view class="summary-card">
    <view class="summary-item urgent">
      <text class="summary-value">{{summary.todayDueSchools}}</text>
      <text class="summary-title">今日截止申请学校</text>
      <text class="summary-desc">最高优先关注</text>
    </view>
    <view class="summary-item recent">
      <text class="summary-value">{{summary.threeDaysDueSchools}}</text>
      <text class="summary-title">3天内截止申请学校</text>
      <text class="summary-desc">建议尽快完成申请</text>
    </view>
    <view class="summary-item changed">
      <text class="summary-value">{{summary.changedSchools}}</text>
      <text class="summary-title">夏令营/预推免信息有变更学校</text>
      <text class="summary-desc">建议尽快人工核实</text>
    </view>
  </view>

  <view class="control-card">
    <view class="view-mode-switch">
      <view
        wx:for="{{viewModes}}"
        wx:key="value"
        class="view-mode-item {{selectedViewMode === item.value ? 'active' : ''}}"
        bindtap="onViewModeTap"
        data-value="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>

    <view wx:if="{{selectedViewMode === 'school'}}">
      <view class="focus-filter-title">学校筛选</view>
      <view class="focus-filters">
        <view
          wx:for="{{schoolFilterOptions}}"
          wx:key="value"
          class="focus-filter-item {{selectedSchoolFilter === item.value ? 'active' : ''}}"
          bindtap="onSchoolFilterTap"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
      <text class="focus-filter-hint">{{schoolFilterHint}}</text>
    </view>

    <view wx:if="{{selectedViewMode === 'task'}}">
      <view class="focus-filter-title">聚焦筛选</view>
      <view class="focus-filters">
        <view
          wx:for="{{focusFilters}}"
          wx:key="value"
          class="focus-filter-item {{selectedFocusFilter === item.value ? 'active' : ''}}"
          bindtap="onFocusFilterTap"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
      <text class="focus-filter-hint">{{focusFilterHint}}</text>
    </view>

  </view>

  <view wx:if="{{selectedViewMode === 'school'}}" class="school-view">
    <view wx:if="{{groupedSchools.length > 0}}">
      <view wx:for="{{groupedSchools}}" wx:key="key" wx:for-item="school" class="school-card">
        <view class="school-header">
          <text class="school-name">{{school.schoolName}}</text>
          <text class="school-count">{{school.unHandledCount}} 条待关注通知</text>
        </view>

        <view class="school-scope-switch">
          <view
            class="school-scope-item {{school.activeScope === 'all' ? 'active' : ''}}"
            bindtap="onSchoolScopeTap"
            data-school-key="{{school.key}}"
            data-scope="all"
          >
            全部 {{school.unHandledCount}}
          </view>
          <view
            class="school-scope-item {{school.activeScope === 'today' ? 'active urgent' : ''}}"
            bindtap="onSchoolScopeTap"
            data-school-key="{{school.key}}"
            data-scope="today"
          >
            今日截止申请 {{school.todayCount}}
          </view>
          <view
            class="school-scope-item {{school.activeScope === 'three_days' ? 'active recent' : ''}}"
            bindtap="onSchoolScopeTap"
            data-school-key="{{school.key}}"
            data-scope="three_days"
          >
            近3天截止申请 {{school.threeDaysCount}}
          </view>
          <view
            class="school-scope-item {{school.activeScope === 'changed' ? 'active changed' : ''}}"
            bindtap="onSchoolScopeTap"
            data-school-key="{{school.key}}"
            data-scope="changed"
          >
            夏令营/预推免信息有变更 {{school.changedCount}}
          </view>
        </view>

        <view wx:if="{{school.scopedPendingCount > 0}}" class="school-pending-list">
          <view wx:for="{{school.visiblePendingReminders}}" wx:key="id" wx:for-item="task" class="school-task-item">
            <view class="school-task-head">
              <text class="school-task-title">{{task.campTitle}}</text>
            </view>

            <view class="school-task-meta">
              <text class="preview-deadline {{task.urgencyBucket}}">{{task.deadlineHintText}}</text>
              <text wx:if="{{task.hasChange}}" class="preview-change">有变更</text>
            </view>

            <text class="school-task-reminder">{{task.reminderHintText}}</text>

            <view class="school-task-text-actions">
              <view
                class="text-action secondary"
                bindtap="onViewCamp"
                data-camp-id="{{task.campId}}"
                data-announcement-type="{{task.announcementType}}"
                data-title="{{task.campTitle}}"
              >
                查看详情
              </view>
              <view class="text-action-divider" wx:if="{{task.canQuickConfirm}}"></view>
              <view
                wx:if="{{task.canQuickConfirm}}"
                class="text-action primary"
                bindtap="onQuickConfirm"
                data-action-token="{{task.actionToken}}"
              >
                {{task.actionLabel || '立即确认'}}
              </view>
              <view class="text-action-divider"></view>
              <view
                class="text-action secondary"
                bindtap="onSnoozeReminder"
                data-reminder-id="{{task.id}}"
              >
                稍后提醒
              </view>
              <view class="text-action-divider"></view>
              <view
                class="text-action {{task.isHandled ? 'warning' : 'primary'}}"
                bindtap="onToggleHandled"
                data-reminder-id="{{task.id}}"
              >
                {{task.isHandled ? '取消已查看' : '标记已查看'}}
              </view>
            </view>
          </view>

          <view
            wx:if="{{!school.expanded && school.morePendingCount > 0}}"
            class="school-expand-hint"
            bindtap="onToggleSchoolExpand"
            data-school-key="{{school.key}}"
          >
            还有 {{school.morePendingCount}} 条待关注通知，点击展开
          </view>

          <view
            wx:if="{{school.expanded && school.scopedPendingCount > 3}}"
            class="school-expand-hint collapse"
            bindtap="onToggleSchoolExpand"
            data-school-key="{{school.key}}"
          >
            收起通知列表
          </view>
        </view>

        <view wx:else class="school-empty-inline">
          当前筛选下该学校暂无待关注通知，可切换标签查看
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-text">{{emptyState.title}}</text>
      <text class="empty-subtext">{{emptyState.desc}}</text>
    </view>
  </view>

  <view wx:if="{{selectedViewMode === 'task'}}" class="task-view">
    <view wx:if="{{taskSections.length > 0}}">
      <view wx:for="{{taskSections}}" wx:key="key" class="task-section">
        <view class="task-section-header">
          <text class="task-section-title">{{item.title}}</text>
          <text class="task-section-count">{{item.list.length}} 条</text>
        </view>

        <view wx:for="{{item.list}}" wx:key="id" wx:for-item="task" class="task-card">
          <view class="task-card-header">
            <text class="task-school">{{task.universityName}}</text>
          </view>

          <text class="task-title">{{task.campTitle}}</text>
          <text class="task-deadline {{task.urgencyBucket}}">{{task.deadlineHintText}}</text>

          <view class="task-info">
            <view class="task-info-row">
              <text class="task-info-label">{{task.eventTimeLabel}}</text>
              <text class="task-info-value">{{task.eventTime || '--'}}</text>
            </view>
            <view class="task-info-row">
              <text class="task-info-label">提醒发送时间</text>
              <text class="task-info-value">{{task.remindTime || '--'}}</text>
            </view>
          </view>

          <view class="task-reminder-hint">
            <text class="task-reminder-hint-label">提醒信息</text>
            <text class="task-reminder-hint-value">{{task.reminderHintText}}</text>
          </view>

          <view wx:if="{{task.hasChange}}" class="task-change-block">
            <text class="task-change-title">信息变更</text>
            <text class="task-change-summary">{{task.changeSummary || '关注信息有更新，建议尽快复核'}}</text>
          </view>

          <view wx:if="{{task.attentionMessages.length > 0}}" class="task-attention-block">
            <text class="task-attention-title">建议关注</text>
            <text wx:for="{{task.attentionMessages}}" wx:key="*this" class="task-attention-item">{{item}}</text>
          </view>

          <view class="task-actions">
            <button
              class="action-btn secondary"
              size="mini"
              bindtap="onViewCamp"
              data-camp-id="{{task.campId}}"
              data-announcement-type="{{task.announcementType}}"
              data-title="{{task.campTitle}}"
            >
              查看详情
            </button>
            <button
              wx:if="{{task.canQuickConfirm}}"
              class="action-btn primary"
              size="mini"
              bindtap="onQuickConfirm"
              data-action-token="{{task.actionToken}}"
            >
              {{task.actionLabel || '立即确认'}}
            </button>
            <button
              class="action-btn secondary"
              size="mini"
              bindtap="onSnoozeReminder"
              data-reminder-id="{{task.id}}"
            >
              稍后提醒
            </button>
            <button
              class="action-btn {{task.isHandled ? 'warning' : 'primary'}}"
              size="mini"
              bindtap="onToggleHandled"
              data-reminder-id="{{task.id}}"
            >
              {{task.isHandled ? '取消已查看' : '标记已查看'}}
            </button>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-text">{{emptyState.title}}</text>
      <text class="empty-subtext">{{emptyState.desc}}</text>
    </view>
  </view>
  </view>

  <view wx:elif="{{activeCenterTab === 'progress'}}" class="progress-tab-view">
    <view class="progress-tip" wx:if="{{progressUseFallback}}">
      {{progressUsingMockData ? '当前展示开发环境演示进展，连接后端后可查看实时数据。' : '当前展示本地缓存进展，连接后端后可查看实时数据。'}}
    </view>

    <view class="progress-tool-entry" bindtap="onOpenSchoolSubscription">
      <view class="progress-tool-main">
        <text class="progress-tool-title">学校级通知设置</text>
        <text class="progress-tool-desc">按学校统一设置通知开关，新增公告自动继承</text>
      </view>
      <text class="progress-tool-arrow">→</text>
    </view>

    <view class="progress-empty" wx:if="{{!progressLoading && progressOverviewList.length === 0}}">
      <text class="empty-text">还没有关注公告</text>
      <text class="empty-subtext">先到夏令营/预推免详情页点击“已关注”</text>
      <button class="progress-refresh-btn" bindtap="onOpenAdvancedSubscription">刷新关注进展</button>
    </view>

    <view class="progress-loading" wx:if="{{progressLoading}}">加载关注进展中...</view>

    <view class="progress-overview-list" wx:if="{{!progressLoading && progressOverviewList.length > 0}}">
      <view
        wx:for="{{progressOverviewList}}"
        wx:key="id"
        class="progress-overview-item"
        data-id="{{item.id}}"
        bindtap="onOpenProgressDetail"
      >
        <view class="progress-overview-head">
          <text class="progress-overview-title">{{item.campTitle}}</text>
          <text class="progress-overview-stage">{{item.stageText}}</text>
        </view>
        <view class="progress-overview-meta">
          <text>{{item.universityName}}</text>
          <text>截止: {{item.deadlineText}}</text>
        </view>
        <text class="progress-overview-next">建议：{{item.nextAction}}</text>
        <view class="progress-overview-meta">
          <text>更新于 {{item.updatedAtText}}</text>
          <text>{{item.subscriptionEnabled ? '通知已开启' : '通知未开启'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
