/* app.wxss */

/* 全局样式重置 - 微信小程序不支持 * 选择器，使用 page 代替 */
page {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

view, text, button, input, textarea, image, scroll-view {
  box-sizing: border-box;
}

/* 字体设置 */
page {
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
  font-size: 16px;
  line-height: 1.5;
  color: #202124;
  background-color: #F4F7FC;
  -webkit-font-smoothing: antialiased;
}

/* 颜色变量 - 微信小程序不支持 :root，使用 page 代替 */
page {
  /* 主色调 */
  --primary-color: #1A73E8;
  --primary-light: #E8F0FE;
  --primary-dark: #1557B0;
  
  /* 功能色 */
  --success-color: #34A853;
  --warning-color: #FBBC04;
  --error-color: #EA4335;
  --info-color: #4285F4;
  
  /* 中性色 */
  --text-primary: #202124;
  --text-secondary: #5F6368;
  --text-tertiary: #80868B;
  --text-placeholder: #9AA0A6;
  --border-color: #DADCE0;
  --background-light: #F8F9FA;
  --background-white: #FFFFFF;
  --surface-page: #F4F7FC;
  --surface-card-bg: linear-gradient(160deg, #ffffff 0%, #f6f9ff 100%);
  --surface-card-bg-soft: linear-gradient(160deg, #ffffff 0%, #f8fbff 100%);
  --surface-card-border: rgba(26, 115, 232, 0.16);
  --surface-card-shadow: 0 8px 22px rgba(26, 115, 232, 0.1);
  --surface-card-shadow-active: 0 12px 28px rgba(26, 115, 232, 0.14);
  --surface-chip-bg: rgba(26, 115, 232, 0.1);

  /* 字体层级 */
  --font-size-caption: 12px;
  --font-size-note: 13px;
  --font-size-body: 14px;
  --font-size-body-lg: 15px;
  --font-size-subtitle: 16px;
  --font-size-title: 18px;
  --font-size-hero: 20px;

  /* 行高层级 */
  --line-height-tight: 1.3;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.6;
  
  /* 间距 */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 20px;
  --spacing-2xl: 24px;
  --spacing-3xl: 32px;

  /* 网格间距（4px基线） */
  --grid-1: 4px;
  --grid-2: 8px;
  --grid-3: 12px;
  --grid-4: 16px;
  --grid-5: 20px;
  --grid-6: 24px;
  --grid-8: 32px;
  
  /* 圆角 */
  --border-radius-xs: 4px;
  --border-radius-sm: 8px;
  --border-radius-md: 12px;
  --border-radius-lg: 16px;
  --border-radius-full: 9999px;
  
  /* 阴影 */
  --shadow-1: 0 3px 10px rgba(15, 40, 90, 0.08);
  --shadow-2: 0 8px 22px rgba(26, 115, 232, 0.1);
  --shadow-3: 0 12px 28px rgba(26, 115, 232, 0.14);
  --shadow-4: 0 18px 36px rgba(26, 115, 232, 0.18);
}

/* 通用样式类 */
.container {
  width: 100%;
  padding: 0 var(--spacing-lg);
  box-sizing: border-box;
}

.card {
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--surface-card-shadow);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.surface-card {
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--surface-card-shadow);
}

.surface-card-soft {
  background: var(--surface-card-bg-soft);
  border: 1px solid rgba(26, 115, 232, 0.12);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-1);
}

.pressable {
  transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
}

.pressable:active {
  transform: translateY(-1px);
  box-shadow: var(--surface-card-shadow-active);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--border-radius-sm);
  font-size: 16px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, #4285F4 100%);
  color: white;
  border: none;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-secondary {
  background-color: var(--background-white);
  color: var(--primary-color);
  border: 1px solid var(--primary-color);
}

.btn-secondary:active {
  background-color: var(--primary-light);
}

.btn-disabled {
  background-color: var(--border-color);
  color: var(--text-placeholder);
  border: none;
  cursor: not-allowed;
}

/* 文本样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

.text-success {
  color: var(--success-color);
}

.text-warning {
  color: var(--warning-color);
}

.text-error {
  color: var(--error-color);
}

.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.text-caption {
  font-size: var(--font-size-caption);
  line-height: var(--line-height-normal);
}

.text-note {
  font-size: var(--font-size-note);
  line-height: var(--line-height-normal);
}

.text-body {
  font-size: var(--font-size-body);
  line-height: var(--line-height-normal);
}

.text-body-lg {
  font-size: var(--font-size-body-lg);
  line-height: var(--line-height-relaxed);
}

.text-subtitle {
  font-size: var(--font-size-subtitle);
  line-height: var(--line-height-tight);
}

.text-title {
  font-size: var(--font-size-title);
  line-height: var(--line-height-tight);
}

.text-hero {
  font-size: var(--font-size-hero);
  line-height: var(--line-height-tight);
}

/* 布局类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 间距类 */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }

.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }

.ml-xs { margin-left: var(--spacing-xs); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.ml-lg { margin-left: var(--spacing-lg); }

.mr-xs { margin-right: var(--spacing-xs); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }
.mr-lg { margin-right: var(--spacing-lg); }

.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }

/* 工具类 */
.hidden {
  display: none;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 状态样式 */
.status-normal {
  color: var(--success-color);
}

.status-warning {
  color: var(--warning-color);
}

.status-error {
  color: var(--error-color);
}

/* 加载动画 */
.loading {
  display: inline-block;
  width: 20px;
  height: 20px;
  border: 2px solid var(--border-color);
  border-radius: 50%;
  border-top-color: var(--primary-color);
  animation: spin 1s ease-in-out infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-3xl) 0;
  color: var(--text-tertiary);
}

.empty-state-icon {
  width: 64px;
  height: 64px;
  margin-bottom: var(--spacing-lg);
  opacity: 0.5;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  page {
    --spacing-lg: 12px;
    --spacing-xl: 16px;
    font-size: 14px;
  }
}
