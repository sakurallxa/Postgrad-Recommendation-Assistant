.container {
  min-height: 100vh;
  background: var(--surface-page);
}

.loading-box {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
}

.loading-text {
  color: var(--text-secondary);
  font-size: var(--font-size-note);
}

.content {
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.summary-card {
  background: var(--surface-card-bg);
  border-radius: var(--border-radius-lg);
  border: 1px solid var(--surface-card-border);
  box-shadow: var(--shadow-2);
  padding: var(--spacing-lg);
}

.summary-card.complete {
  border-color: rgba(46, 125, 50, 0.28);
  background: linear-gradient(160deg, #ffffff 0%, #f3fbf4 100%);
}

.summary-card.partial {
  border-color: rgba(26, 115, 232, 0.22);
}

.summary-title {
  display: block;
  font-size: var(--font-size-note);
  color: var(--text-secondary);
}

.summary-value {
  display: block;
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-title);
  line-height: var(--line-height-tight);
  color: var(--text-primary);
  font-weight: 700;
}

.summary-desc {
  display: block;
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-caption);
  color: var(--text-tertiary);
  line-height: var(--line-height-relaxed);
}

.section-card {
  background: var(--surface-card-bg);
  border-radius: var(--border-radius-lg);
  border: 1px solid var(--surface-card-border);
  box-shadow: var(--shadow-1);
  padding: var(--spacing-lg);
}

.section-head {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-subtitle);
  color: var(--text-primary);
  line-height: var(--line-height-tight);
  font-weight: 700;
}

.section-note {
  font-size: var(--font-size-caption);
  color: var(--text-secondary);
  line-height: var(--line-height-normal);
}

.field-row {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-md);
}

.field-row:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: var(--font-size-note);
  color: var(--text-secondary);
  line-height: var(--line-height-normal);
}

.field-input,
.picker-value {
  width: 100%;
  min-height: 44px;
  border-radius: var(--border-radius-md);
  border: 1px solid rgba(26, 115, 232, 0.2);
  background: rgba(255, 255, 255, 0.95);
  padding: 10px 12px;
  font-size: var(--font-size-body);
  color: var(--text-primary);
  line-height: 24px;
}

.school-suggestions {
  margin-top: var(--spacing-xs);
  border: 1px solid rgba(26, 115, 232, 0.2);
  border-radius: var(--border-radius-md);
  background: rgba(255, 255, 255, 0.98);
  overflow: hidden;
}

.school-suggestion-item {
  padding: 10px 12px;
  border-bottom: 1px solid rgba(26, 115, 232, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-sm);
}

.school-suggestion-item:last-child {
  border-bottom: none;
}

.school-name {
  font-size: var(--font-size-body);
  color: var(--text-primary);
}

.school-level {
  font-size: var(--font-size-caption);
  color: var(--primary-color);
  background: rgba(26, 115, 232, 0.08);
  border-radius: var(--border-radius-full);
  padding: 2px 8px;
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-top: calc(var(--spacing-xs) * -1);
  margin-bottom: var(--spacing-md);
}

.quick-tag {
  padding: 6px 12px;
  border-radius: var(--border-radius-full);
  border: 1px solid rgba(26, 115, 232, 0.2);
  background: rgba(26, 115, 232, 0.06);
  color: var(--primary-color);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-normal);
}

.quick-tag.active {
  color: #ffffff;
  background: var(--primary-color);
}

.field-group {
  margin-bottom: var(--spacing-md);
}

.choice-row {
  margin-top: var(--spacing-xs);
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.choice-pill {
  padding: 6px 12px;
  border-radius: var(--border-radius-full);
  border: 1px solid rgba(95, 99, 104, 0.2);
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.9);
  font-size: var(--font-size-caption);
}

.choice-pill.active {
  border-color: rgba(26, 115, 232, 0.3);
  color: var(--primary-color);
  background: rgba(26, 115, 232, 0.1);
  font-weight: 600;
}

.textarea-row .field-textarea {
  width: 100%;
  min-height: 100px;
  border-radius: var(--border-radius-md);
  border: 1px solid rgba(26, 115, 232, 0.2);
  background: rgba(255, 255, 255, 0.95);
  padding: 10px 12px;
  font-size: var(--font-size-body);
  color: var(--text-primary);
  line-height: var(--line-height-relaxed);
}

.hint-card {
  border-radius: var(--border-radius-md);
  background: rgba(251, 188, 4, 0.14);
  color: #8a6d00;
  font-size: var(--font-size-caption);
  line-height: var(--line-height-relaxed);
  padding: var(--spacing-sm) var(--spacing-md);
}

.bottom-gap {
  height: 136px;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-lg) calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  background: #f4f7fc;
  border-top: 1px solid rgba(26, 115, 232, 0.15);
  box-shadow: 0 -8px 20px rgba(26, 115, 232, 0.08);
}

.btn-reset,
.btn-save {
  flex: 1;
  height: 44px;
  min-height: 44px;
  border-radius: var(--border-radius-md);
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 44px;
  box-sizing: border-box;
  white-space: nowrap;
  font-size: var(--font-size-body);
  font-weight: 700;
}

.btn-reset {
  background: #ffffff;
  color: var(--text-secondary);
  border: 1px solid rgba(95, 99, 104, 0.24);
  opacity: 1;
}

.btn-save {
  background: linear-gradient(135deg, #1a73e8 0%, #4f93ff 100%);
  color: #ffffff;
  border: 1px solid transparent;
  opacity: 1;
}

.btn-reset::after,
.btn-save::after {
  border: none;
}
