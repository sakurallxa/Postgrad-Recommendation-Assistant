  "tabBar": {
    "color": "#5F6368",
    "selectedColor": "#1A73E8",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "assets/images/icons/tab-home.png",
        "selectedIconPath": "assets/images/icons/tab-home-active.png"
      },
      {
        "pagePath": "pages/my-reminders/index",
        "text": "通知中心",
        "iconPath": "assets/images/icons/tab-reminder.png",
        "selectedIconPath": "assets/images/icons/tab-reminder-active.png"
      },
      {
        "pagePath": "pages/my/my",
        "text": "个人中心",
        "iconPath": "assets/images/icons/tab-my.png",
        "selectedIconPath": "assets/images/icons/tab-my-active.png"
      }
    ]
  },
  "sitemapLocation": "sitemap.json"
