  "subpackages": [
    {
      "root": "packageCamp",
      "name": "camp",
      "pages": [
        "pages/camp-list/index",
        "pages/camp-detail/index",
        "pages/source-view/index"
      ]
    },
    {
      "root": "packageSelector",
      "name": "selector",
      "pages": [
        "pages/selector/index",
        "pages/university-list/index",
        "pages/major-list/index"
      ]
    },
    {
      "root": "packageReminder",
      "name": "reminder",
      "pages": [
        "pages/reminder-create/index"
      ]
    },
    {
      "root": "packageProgress",
      "name": "progress",
      "pages": [
        "pages/progress-list/index",
        "pages/progress-detail/index",
        "pages/school-subscription/index",
        "pages/action-landing/index"
      ]
    },
    {
      "root": "packageProfile",
      "name": "profile",
      "pages": [
        "pages/profile/index"
      ]
    }
