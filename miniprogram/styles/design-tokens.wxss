/**
 * v0.2 设计系统 - "清爽呼吸感" 风格
 * 适合小程序的精简、留白、轻量化设计
 */

page {
  /* ========== 颜色 ========== */
  /* 主色 - 沉稳的蓝紫，比微信绿更现代 */
  --color-primary: #4F46E5;
  --color-primary-soft: rgba(79, 70, 229, 0.08);
  --color-primary-hover: #4338CA;

  /* 语义色 */
  --color-success: #10B981;
  --color-success-soft: rgba(16, 185, 129, 0.10);
  --color-warning: #F59E0B;
  --color-warning-soft: rgba(245, 158, 11, 0.12);
  --color-danger: #EF4444;
  --color-danger-soft: rgba(239, 68, 68, 0.10);

  /* 文字 */
  --text-primary: #111827;     /* 主标题/正文 */
  --text-secondary: #4B5563;   /* 次要信息 */
  --text-tertiary: #9CA3AF;    /* 辅助/弱化 */
  --text-disabled: #D1D5DB;

  /* 背景 & 表面 */
  --bg-page: #F9FAFB;
  --bg-surface: #FFFFFF;
  --bg-elevated: #FFFFFF;
  --bg-muted: #F3F4F6;

  /* 边框 */
  --border-light: #F3F4F6;
  --border-default: #E5E7EB;
  --border-strong: #D1D5DB;

  /* ========== 字号 ========== */
  --text-xs: 22rpx;      /* 11px - 辅助说明 */
  --text-sm: 26rpx;      /* 13px - 次要文本 */
  --text-base: 28rpx;    /* 14px - 正文 */
  --text-md: 32rpx;      /* 16px - 强调正文 */
  --text-lg: 36rpx;      /* 18px - 子标题 */
  --text-xl: 44rpx;      /* 22px - 标题 */
  --text-2xl: 56rpx;     /* 28px - 大标题 */

  /* ========== 间距（呼吸感的核心） ========== */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 48rpx;
  --space-6: 64rpx;
  --space-7: 96rpx;

  /* ========== 圆角 ========== */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-pill: 999rpx;

  /* ========== 阴影 ========== */
  --shadow-xs: 0 1rpx 2rpx rgba(17, 24, 39, 0.04);
  --shadow-sm: 0 2rpx 8rpx rgba(17, 24, 39, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(17, 24, 39, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(17, 24, 39, 0.10);

  /* ========== 行高 ========== */
  --leading-tight: 1.25;
  --leading-normal: 1.5;
  --leading-relaxed: 1.625;

  /* 字重 */
  --weight-regular: 400;
  --weight-medium: 500;
  --weight-semibold: 600;
  --weight-bold: 700;

  /* 页面基础 */
  background: var(--bg-page);
  color: var(--text-primary);
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
}

/* ========== 通用工具类 ========== */

/* 卡片 */
.card {
  background: var(--bg-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
}

/* 主按钮 */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-md);
  border: none;
  line-height: 1.4;
}
.btn-primary[disabled] {
  background: var(--text-disabled);
  color: #FFFFFF;
}
.btn-primary:active {
  background: var(--color-primary-hover);
}

/* 次要按钮 */
.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  color: var(--text-primary);
  font-size: var(--text-base);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--border-default);
  line-height: 1.4;
}
.btn-secondary:active {
  background: var(--bg-muted);
}

/* 文字按钮 */
.btn-text {
  color: var(--color-primary);
  font-size: var(--text-base);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: var(--text-xs);
  line-height: 1.6;
  background: var(--bg-muted);
  color: var(--text-secondary);
}
.tag-primary { background: var(--color-primary-soft); color: var(--color-primary); }
.tag-success { background: var(--color-success-soft); color: var(--color-success); }
.tag-warning { background: var(--color-warning-soft); color: #B45309; }
.tag-danger  { background: var(--color-danger-soft); color: var(--color-danger); }

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-light);
  margin: var(--space-3) 0;
}

/* 空状态 */
.empty-state {
  padding: var(--space-7) var(--space-3);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  color: var(--text-tertiary);
}
.empty-state-icon { font-size: 80rpx; margin-bottom: var(--space-3); opacity: 0.5; }
.empty-state-text { font-size: var(--text-sm); }

/* 加载占位 */
.skeleton {
  background: linear-gradient(90deg, var(--bg-muted) 25%, var(--bg-elevated) 50%, var(--bg-muted) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-md);
  animation: skeleton-shimmer 1.4s ease-in-out infinite;
}
@keyframes skeleton-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
