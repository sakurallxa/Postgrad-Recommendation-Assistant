<view class="camp-card {{statusClass}}" bindtap="handleTap">
  <view class="card-header">
    <image 
      wx:if="{{universityLogoResolved}}" 
      class="university-logo" 
      src="{{universityLogoResolved}}" 
      mode="aspectFit"
      lazy-load
    />
    <view class="header-info">
      <view class="header-tags">
        <view class="university-tag">{{camp.universityName}}</view>
        <view class="announcement-type-tag {{announcementTypeClass}}">{{announcementTypeLabel}}</view>
      </view>
      <text class="camp-title">{{camp.title}}</text>
    </view>
  </view>

  <view class="card-body">
    <view class="info-grid">
      <view class="info-item" wx:if="{{scheduleText}}">
        <view class="info-icon">📅</view>
        <view class="info-content">
          <text class="info-label">{{scheduleLabel}}</text>
          <text class="info-value">{{scheduleText}}</text>
        </view>
      </view>
      <view class="info-item" wx:if="{{camp.location}}">
        <view class="info-icon">📍</view>
        <view class="info-content">
          <text class="info-label">举办地点</text>
          <text class="info-value">{{camp.location}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card-footer">
    <view class="deadline {{statusClass}}">
      <view class="deadline-icon">⏰</view>
      <view class="deadline-content">
        <text class="deadline-text">{{deadlineText}}</text>
        <text class="days-remaining" wx:if="{{daysRemaining > 0}}">剩余{{daysRemaining}}天</text>
      </view>
    </view>
    <view class="actions">
      <view
        wx:if="{{camp.hasReminder}}"
        class="reminder-status"
        catchtap="handleRemindTap"
        hover-class="reminder-status-hover"
      >
        <text class="reminder-icon">🔔</text>
        <text class="reminder-text">已设置提醒</text>
      </view>
      <button
        wx:else
        class="remind-btn"
        size="mini"
        catchtap="handleRemindTap"
      >
        设置提醒
      </button>
    </view>
  </view>

  <!-- 数据新鲜度（β场景信任锚点）-->
  <view class="freshness-row" wx:if="{{freshnessText}}">
    <text class="freshness-text">{{freshnessText}}</text>
  </view>
</view>
