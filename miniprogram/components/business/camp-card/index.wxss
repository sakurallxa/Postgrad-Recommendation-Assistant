/* 夏令营卡片组件样式 */

.camp-card {
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-2);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.camp-card:active {
  box-shadow: var(--surface-card-shadow-active);
  transform: translateY(-1px);
}

/* 卡片头部 */
.card-header {
  display: flex;
  margin-bottom: var(--spacing-md);
}

.university-logo {
  width: 44px;
  height: 44px;
  border-radius: var(--border-radius-md);
  margin-right: var(--spacing-md);
  background-color: var(--background-light);
}

.header-info {
  flex: 1;
  min-width: 0;
}

.header-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-bottom: var(--spacing-sm);
}

/* 院校标签样式 */
.university-tag {
  display: inline-block;
  font-size: var(--font-size-caption);
  font-weight: 600;
  color: var(--primary-color);
  background: linear-gradient(135deg, var(--primary-light) 0%, rgba(74, 144, 226, 0.12) 100%);
  padding: 4px 10px;
  border-radius: var(--border-radius-sm);
  border: 1px solid rgba(74, 144, 226, 0.15);
}

.announcement-type-tag {
  display: inline-flex;
  align-items: center;
  font-size: var(--font-size-caption);
  font-weight: 500;
  padding: 4px 10px;
  border-radius: var(--border-radius-sm);
  border: 1px solid transparent;
}

.announcement-type-tag.summer-camp {
  color: #2d6cdf;
  background: rgba(45, 108, 223, 0.12);
  border-color: rgba(45, 108, 223, 0.2);
}

.announcement-type-tag.pre-recommendation {
  color: #c15a1d;
  background: rgba(193, 90, 29, 0.12);
  border-color: rgba(193, 90, 29, 0.2);
}

.camp-title {
  font-size: var(--font-size-subtitle);
  font-weight: 600;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: var(--line-height-normal);
}

/* 卡片主体 - 网格布局 */
.card-body {
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-md) 0;
  border-top: 1px solid rgba(95, 99, 104, 0.2);
  border-bottom: 1px solid rgba(95, 99, 104, 0.2);
}

.info-grid {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.info-item {
  display: flex;
  align-items: flex-start;
}

.info-icon {
  font-size: 16px;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
  margin-top: 2px;
}

.info-content {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.info-label {
  font-size: var(--font-size-caption);
  color: var(--text-tertiary);
  margin-bottom: 2px;
  line-height: var(--line-height-normal);
}

.info-value {
  font-size: var(--font-size-body);
  color: var(--text-primary);
  font-weight: 500;
  line-height: var(--line-height-normal);
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.deadline {
  display: flex;
  align-items: center;
  flex: 1;
}

.deadline-icon {
  font-size: 16px;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.deadline-content {
  display: flex;
  flex-direction: column;
}

.deadline-text {
  font-size: var(--font-size-body);
  font-weight: 600;
  line-height: var(--line-height-normal);
}

.days-remaining {
  font-size: var(--font-size-caption);
  font-weight: 400;
  margin-top: 2px;
  line-height: var(--line-height-normal);
}

.deadline.normal {
  color: var(--success-color);
}

.deadline.warning {
  color: var(--warning-color);
}

.deadline.urgent {
  color: var(--error-color);
}

.deadline.expired {
  color: var(--text-tertiary);
}

/* 操作区 */
.actions {
  display: flex;
  align-items: center;
}

.reminder-status {
  display: flex;
  align-items: center;
  font-size: var(--font-size-caption);
  color: var(--primary-color);
  background-color: var(--surface-chip-bg);
  padding: 6px 12px;
  border-radius: var(--border-radius-sm);
  border: 1px solid rgba(26, 115, 232, 0.18);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.reminder-status-hover {
  opacity: 0.8;
  transform: translateY(-1px);
}

.reminder-icon {
  margin-right: var(--spacing-xs);
  font-size: 14px;
}

.reminder-text {
  font-weight: 500;
}

.remind-btn {
  font-size: var(--font-size-caption);
  padding: 6px 14px;
  border-radius: var(--border-radius-sm);
  background-color: rgba(255, 255, 255, 0.92);
  color: var(--primary-color);
  border: 1px solid var(--primary-color);
  line-height: var(--line-height-normal);
}

.remind-btn::after {
  border-radius: var(--border-radius-sm);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .camp-card {
    padding: var(--spacing-md);
  }
  
  .university-logo {
    width: 36px;
    height: 36px;
  }
  
  .camp-title {
    font-size: 15px;
  }
  
  .deadline-text {
    font-size: 13px;
  }
  
  .days-remaining {
    font-size: 11px;
  }
}

/* 数据新鲜度展示（β场景信任锚点）*/
.freshness-row {
  margin-top: 8rpx;
  padding: 8rpx 16rpx 0;
  border-top: 1rpx dashed #e5e5e5;
}
.freshness-text {
  font-size: 22rpx;
  color: #999;
}
