<view class="container">
  <!-- 院校信息 -->
  <view class="university-info">
    <image 
      wx:if="{{camp.universityLogo}}" 
      class="university-logo" 
      src="{{camp.universityLogo}}" 
      mode="aspectFit"
    />
    <text class="university-name">{{camp.universityName}}</text>
  </view>

  <!-- 夏令营标题 -->
  <view class="camp-title">
    {{camp.title}}
  </view>

  <!-- 基本信息 -->
  <view class="section">
    <text class="section-title">基本信息</text>
    <view class="info-card">
      <view class="info-item">
        <text class="label">发布日期</text>
        <text class="value">{{camp.publishDate || '待定'}}</text>
      </view>
      <view class="info-item">
        <text class="label">报名截止</text>
        <text class="value deadline {{deadlineStatusClass}}">{{camp.deadline || '待定'}}</text>
      </view>
      <view class="info-item">
        <text class="label">举办时间</text>
        <text class="value">{{camp.startDate || '待定'}} ~ {{camp.endDate || '待定'}}</text>
      </view>
      <view class="info-item">
        <text class="label">举办地点</text>
        <text class="value">{{camp.location || '待定'}}</text>
      </view>
    </view>
  </view>

  <!-- 申请条件 -->
  <view class="section" wx:if="{{camp.requirements}}">
    <text class="section-title">申请条件</text>
    <view class="info-card">
      <view class="requirement-item" wx:for="{{camp.requirements}}" wx:key="{{index}}">
        <text class="requirement-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 所需材料 -->
  <view class="section" wx:if="{{camp.materials && camp.materials.length > 0}}">
    <view class="section-header">
      <text class="section-title">所需材料</text>
      <button class="copy-btn" size="mini" bindtap="handleCopyMaterials">
        一键复制
      </button>
    </view>
    <view class="info-card">
      <view class="material-item" wx:for="{{camp.materials}}" wx:key="{{index}}">
        <text class="material-icon">•</text>
        <text class="material-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 报名流程 -->
  <view class="section" wx:if="{{camp.process && camp.process.length > 0}}">
    <text class="section-title">报名流程</text>
    <view class="info-card">
      <view class="process-item" wx:for="{{camp.process}}" wx:key="{{index}}">
        <view class="process-step">{{index + 1}}</view>
        <view class="process-content">
          <text class="process-action">{{item.action}}</text>
          <text class="process-deadline" wx:if="{{item.deadline}}">截止: {{item.deadline}}</text>
          <text class="process-note" wx:if="{{item.note}}">{{item.note}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 原文链接 -->
  <view class="section" wx:if="{{camp.sourceUrl}}">
    <text class="section-title">原文链接</text>
    <view class="info-card">
      <view class="source-link" bindtap="handleOpenSource">
        <text class="link-text">{{camp.sourceUrl}}</text>
        <text class="link-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="bottom-action">
    <button class="remind-btn" bindtap="handleSetReminder">
      {{camp.hasReminder ? '已设置提醒' : '设置提醒'}}
    </button>
  </view>
</view>