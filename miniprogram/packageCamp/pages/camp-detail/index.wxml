<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading"></view>
    <text class="loading-text">加载中...</text>
  </view>
  
  <!-- 内容区域 -->
  <view wx:else>
    <!-- 院校信息 -->
    <view class="university-header">
      <view class="university-info">
        <image 
          class="university-logo" 
          src="{{campDetail.universityLogo || '/assets/images/icons/user.png'}}" 
          mode="aspectFit"
          binderror="handleUniversityLogoError"
        />
        <view class="header-tags">
          <view class="university-tag">{{campDetail.universityName}}</view>
          <view class="announcement-tag {{campDetail.announcementType === 'pre_recommendation' ? 'pre-recommendation' : 'summer-camp'}}">
            {{campDetail.announcementTypeLabel || '夏令营公告'}}
          </view>
        </view>
      </view>
    </view>

    <!-- 夏令营标题 -->
    <view class="camp-title">
      {{campDetail.title}}
    </view>

    <!-- 快速导航 -->
    <view class="quick-nav">
      <view class="quick-nav-chip" data-target="section-basic" bindtap="onJumpSection">基本信息</view>
      <view class="quick-nav-chip" wx:if="{{campDetail.showRequirementsSection}}" data-target="section-requirements" bindtap="onJumpSection">申请条件</view>
      <view class="quick-nav-chip" wx:if="{{campDetail.showMaterialsSection}}" data-target="section-materials" bindtap="onJumpSection">所需材料</view>
      <view class="quick-nav-chip" wx:if="{{campDetail.showProcessSection}}" data-target="section-process" bindtap="onJumpSection">流程</view>
      <view class="quick-nav-chip" wx:if="{{campDetail.showOriginalContentSection}}" data-target="section-original" bindtap="onJumpSection">原文展示</view>
      <view class="quick-nav-chip" data-target="section-contact" bindtap="onJumpSection">联系方式</view>
      <view class="quick-nav-chip" data-target="section-source" bindtap="onJumpSection">来源与可信度</view>
    </view>

    <!-- 风险提示（轻量Tips） -->
    <view class="inline-tips" wx:if="{{campDetail.riskHints && campDetail.riskHints.length > 0}}">
      <text class="tips-badge">Tips</text>
      <view class="tips-content">
        <text class="tips-line" wx:for="{{campDetail.riskHints}}" wx:key="index">{{item.title}}：{{item.content}}</text>
      </view>
    </view>

    <!-- 基本信息 -->
    <view id="section-basic" class="section">
      <text class="section-title">基本信息</text>
      <view class="info-card">
        <view class="info-item">
          <text class="label">发布日期</text>
          <text class="value">{{campDetail.publishDate || '待定'}}</text>
        </view>
        <view class="info-item">
          <text class="label">报名截止</text>
          <text class="value deadline">{{campDetail.deadline || '待定'}}</text>
        </view>
        <view class="info-item">
          <text class="label">举办时间</text>
          <text class="value">{{campDetail.eventDateText || '待定'}}</text>
        </view>
        <view class="info-item">
          <text class="label">举办地点</text>
          <text class="value">{{campDetail.location || '待定'}}</text>
        </view>
      </view>
    </view>

    <!-- 申请条件 -->
    <view id="section-requirements" class="section" wx:if="{{campDetail.showRequirementsSection}}">
      <text class="section-title">申请条件</text>
      <view class="info-card">
        <view class="compare-summary {{campDetail.profileComparison.status}}">
          <text class="compare-summary-label">与你的情况对比：{{campDetail.profileComparison.label}}</text>
          <text class="compare-summary-desc">{{campDetail.profileComparison.description}}</text>
          <view class="compare-summary-action" wx:if="{{!campDetail.profileComparison.hasProfile}}" bindtap="handleGoProfile">
            去完善个人档案
          </view>
        </view>

        <view class="requirement-group" wx:if="{{campDetail.requirements.hardConstraints && campDetail.requirements.hardConstraints.length > 0}}">
          <text class="requirement-group-title">硬性门槛</text>
          <view class="requirement-item" wx:for="{{campDetail.requirements.hardConstraints}}" wx:key="index" wx:if="{{expandHardConstraints || index < 2}}">
            <view class="requirement-item-header">
              <text class="requirement-item-title">{{item.title}}</text>
              <text class="requirement-match {{item.matchStatus}}">{{item.matchStatusLabel || '未知'}}</text>
            </view>
            <text class="requirement-text">{{item.content}}</text>
            <view class="requirement-meta">
              <text class="requirement-meta-text">原文描述：<text class="source-quote-mark">“</text><text class="source-highlight">{{item.sourceSnippet}}</text><text class="source-quote-mark">”</text></text>
              <text class="requirement-meta-text" wx:if="{{item.matchReason}}">个人匹配信息：{{item.matchReason}}</text>
            </view>
          </view>
          <view class="section-toggle" wx:if="{{campDetail.requirements.hardConstraints.length > 2}}" data-key="expandHardConstraints" bindtap="onToggleExpand">
            {{expandHardConstraints ? '收起' : '展开更多'}}
          </view>
        </view>

        <view class="requirement-group" wx:if="{{campDetail.requirements.softSuggestions && campDetail.requirements.softSuggestions.length > 0}}">
          <text class="requirement-group-title">软性建议</text>
          <view class="requirement-item soft" wx:for="{{campDetail.requirements.softSuggestions}}" wx:key="index" wx:if="{{expandSoftSuggestions || index < 2}}">
            <text class="requirement-item-title">{{item.title}}</text>
            <text class="requirement-text">{{item.content}}</text>
            <view class="requirement-meta">
              <text class="requirement-meta-text">原文描述：<text class="source-quote-mark">“</text><text class="source-highlight">{{item.sourceSnippet}}</text><text class="source-quote-mark">”</text></text>
            </view>
          </view>
          <view class="section-toggle" wx:if="{{campDetail.requirements.softSuggestions.length > 2}}" data-key="expandSoftSuggestions" bindtap="onToggleExpand">
            {{expandSoftSuggestions ? '收起' : '展开更多'}}
          </view>
        </view>

        <view class="requirement-group" wx:if="{{campDetail.requirements.uncertainItems && campDetail.requirements.uncertainItems.length > 0}}">
          <text class="requirement-group-title">不确定项</text>
          <view class="requirement-item uncertain" wx:for="{{campDetail.requirements.uncertainItems}}" wx:key="index" wx:if="{{expandUncertainItems || index < 2}}">
            <text class="requirement-item-title">{{item.title}}</text>
            <text class="requirement-text">{{item.content}}</text>
            <view class="requirement-meta">
              <text class="requirement-meta-text">原文描述：<text class="source-quote-mark">“</text><text class="source-highlight">{{item.sourceSnippet}}</text><text class="source-quote-mark">”</text></text>
            </view>
          </view>
          <view class="section-toggle" wx:if="{{campDetail.requirements.uncertainItems.length > 2}}" data-key="expandUncertainItems" bindtap="onToggleExpand">
            {{expandUncertainItems ? '收起' : '展开更多'}}
          </view>
        </view>
      </view>
    </view>

    <!-- 所需材料 -->
    <view id="section-materials" class="section" wx:if="{{campDetail.showMaterialsSection}}">
      <view class="section-header">
        <text class="section-title">所需材料</text>
        <button class="copy-btn" size="mini" bindtap="handleCopyMaterials">
          一键复制
        </button>
      </view>
      <view class="info-card materials-card">
        <view class="material-item {{item.isHighlighted ? 'highlighted' : ''}}" wx:for="{{campDetail.materials}}" wx:key="index" wx:if="{{expandMaterials || index < 4}}">
          <text class="material-title">{{item.title || item}}</text>
          <text class="material-desc" wx:if="{{item.detail}}">{{item.detail}}</text>
          <text class="material-link-tip" wx:if="{{item.isHighlighted}}">{{item.highlightReason || '申请条件已提及该材料'}}</text>
        </view>
        <view class="section-toggle" wx:if="{{campDetail.materials.length > 4}}" data-key="expandMaterials" bindtap="onToggleExpand">
          {{expandMaterials ? '收起' : '展开更多'}}
        </view>
      </view>
    </view>

    <!-- 夏令营流程 -->
    <view id="section-process" class="section" wx:if="{{campDetail.showProcessSection}}">
      <text class="section-title">夏令营/预推免流程</text>
      <view class="info-card">
        <view class="timeline">
          <view class="timeline-item" wx:for="{{campDetail.process}}" wx:key="index">
            <view class="timeline-marker">
              <view class="timeline-dot active">{{index + 1}}</view>
              <view class="timeline-line" wx:if="{{index < campDetail.process.length - 1}}"></view>
            </view>
            <view class="timeline-content">
              <view class="timeline-header">
                <text class="timeline-title">{{item.action}}</text>
              </view>
              <text class="timeline-deadline" wx:if="{{item.deadline}}">
                <text class="deadline-label">截止时间：</text>{{item.deadline}}
              </text>
              <text class="timeline-note" wx:if="{{item.period}}">{{item.period}}</text>
              <text class="timeline-note" wx:if="{{item.note}}">{{item.note}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view id="section-original" class="section" wx:if="{{campDetail.showOriginalContentSection}}">
      <text class="section-title">原文展示</text>
      <view class="info-card raw-process-card">
        <view class="raw-process-header">
          <text class="raw-process-badge">官网原文</text>
          <text class="raw-process-tip">以下为抓取到的公告原文全文展示，便于直接核对官网内容。</text>
        </view>
        <view class="raw-process-text">{{campDetail.originalContentDisplay}}</view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view id="section-contact" class="section" wx:if="{{campDetail.contact && campDetail.contact.hasData}}">
      <text class="section-title">联系方式</text>
      <view class="info-card">
        <view class="contact-item" wx:if="{{campDetail.contact.email}}">
          <text class="label">邮箱</text>
          <text class="value">{{campDetail.contact.email}}</text>
        </view>
        <view class="contact-item" wx:if="{{campDetail.contact.phone}}">
          <text class="label">电话</text>
          <text class="value">{{campDetail.contact.phone}}</text>
        </view>
        <view class="contact-item" wx:if="{{campDetail.contact.address}}">
          <text class="label">地址</text>
          <text class="value">{{campDetail.contact.address}}</text>
        </view>
        <view class="contact-item" wx:for="{{campDetail.contact.other}}" wx:key="index">
          <text class="label">其他</text>
          <text class="value">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 信息来源与可信度 -->
    <view id="section-source" class="section" wx:if="{{campDetail.transparencyMeta}}">
      <text class="section-title">信息来源与说明</text>
      <view class="info-card">
        <view class="source-actions" wx:if="{{campDetail.transparencyMeta.sourceUrl}}">
          <view class="source-link source-link-primary" bindtap="handleCopySourceUrl">
            <text class="link-text">复制官网原文链接</text>
          </view>
        </view>
        <view class="source-link source-link-raw" bindtap="handleCopySourceUrl" wx:if="{{campDetail.transparencyMeta.sourceUrl}}">
          <text class="link-text">{{campDetail.transparencyMeta.sourceUrl}}</text>
        </view>
        <view class="transparency-item">
          <text class="label">抓取时间</text>
          <text class="value">{{campDetail.transparencyMeta.crawledAtText}}</text>
        </view>
        <view class="transparency-item">
          <text class="label">最近更新</text>
          <text class="value">{{campDetail.transparencyMeta.updatedAtText}}</text>
        </view>
        <view class="transparency-item">
          <text class="label">来源参考性</text>
          <text class="value">{{campDetail.transparencyMeta.confidenceLabel}}</text>
        </view>
        <view class="transparency-item">
          <text class="label">说明</text>
          <text class="value">{{campDetail.transparencyMeta.confidenceDescription}}</text>
        </view>
        <view class="transparency-item">
          <text class="label">摘要范围</text>
          <text class="value">仅展示高置信结构化信息，未展示字段请以官网原文为准</text>
        </view>
      </view>
    </view>

    <!-- 底部操作区 -->
    <view class="bottom-action">
      <button
        class="progress-btn {{campDetail.hasProgress ? 'danger' : ''}}"
        bindtap="handleToggleProgress"
      >
        {{campDetail.hasProgress ? '取消关注' : '加入关注'}}
      </button>
      <button class="remind-btn" bindtap="handleSetReminder">
        {{campDetail.hasReminder ? '已设置提醒' : '设置提醒'}}
      </button>
    </view>

    <!-- 报错入口（β场景反馈闭环） -->
    <view class="report-issue-row" bindtap="onTapReportIssue">
      <text class="report-issue-icon">⚠</text>
      <text class="report-issue-text">信息有误？点击反馈</text>
    </view>
  </view>
  
  <!-- 复制成功提示 -->
  <view wx:if="{{showCopySuccess}}" class="copy-success">
    复制成功
  </view>
</view>
