<view class="reminders-page">
  <!-- 筛选栏 -->
  <view class="filter-section">
    <view 
      wx:for="{{filterOptions}}" 
      wx:key="value"
      class="filter-tag {{selectedFilter === item.value ? 'active' : ''}}"
      bindtap="onFilterTap"
      data-value="{{item.value}}"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 提醒列表 -->
  <view class="reminder-list-section">
    <view 
      wx:for="{{filteredReminders}}" 
      wx:key="id"
      class="reminder-item"
    >
      <view class="reminder-header">
        <text class="camp-title">{{item.campTitle}}</text>
        <text class="reminder-status {{item.status}}">{{item.statusText}}</text>
      </view>
      
      <view class="reminder-info">
        <view class="info-row">
          <icon class="info-icon" type="calendar" size="16" color="#80868B" />
          <text class="info-text">截止日期: {{item.deadline}}</text>
        </view>
        <view class="info-row">
          <icon class="info-icon" type="clock" size="16" color="#80868B" />
          <text class="info-text">提醒时间: {{item.remindTime}}</text>
        </view>
        <view class="info-row" wx:if="item.universityName">
          <icon class="info-icon" type="location" size="16" color="#80868B" />
          <text class="info-text">{{item.universityName}}</text>
        </view>
      </view>
      
      <view class="reminder-actions">
        <button 
          class="action-btn secondary" 
          size="mini" 
          bindtap="onViewCamp"
          data-camp-id="{{item.campId}}"
          data-announcement-type="{{item.announcementType}}"
          data-title="{{item.campTitle}}"
        >
          查看详情
        </button>
        <button 
          class="action-btn danger" 
          size="mini" 
          bindtap="onDeleteReminder"
          data-reminder-id="{{item.id}}"
        >
          删除
        </button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredReminders.length === 0}}">
      <icon type="info-circle" size="64" color="#DADCE0" />
      <text class="empty-text">暂无提醒</text>
      <text class="empty-subtext">在夏令营/预推免详情页设置提醒</text>
    </view>
  </view>
</view>
