/* 我的提醒页样式 */
.reminders-page {
  min-height: 100vh;
  background-color: var(--surface-page);
}

/* 筛选栏 */
.filter-section {
  background: var(--surface-card-bg-soft);
  border: 1px solid rgba(26, 115, 232, 0.12);
  border-radius: 14px;
  padding: var(--grid-3) var(--grid-4);
  display: flex;
  flex-wrap: wrap;
  gap: var(--grid-2);
  margin: var(--grid-3) var(--grid-4) 0;
  box-shadow: var(--shadow-1);
}

.filter-tag {
  padding: 6px var(--grid-4);
  border: 1px solid rgba(95, 99, 104, 0.24);
  border-radius: 16px;
  font-size: var(--font-size-body);
  color: var(--text-secondary);
  background-color: rgba(255, 255, 255, 0.96);
}

.filter-tag.active {
  background-color: var(--surface-chip-bg);
  border-color: var(--primary-color);
  color: var(--primary-color);
  font-weight: 600;
}

/* 提醒列表 */
.reminder-list-section {
  padding: var(--grid-3) var(--grid-4);
}

.reminder-item {
  background: var(--surface-card-bg);
  border-radius: 16px;
  border: 1px solid var(--surface-card-border);
  padding: var(--grid-4);
  margin-bottom: var(--grid-3);
  box-shadow: var(--shadow-2);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.reminder-item:active {
  transform: translateY(-1px);
  box-shadow: var(--surface-card-shadow-active);
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--grid-3);
}

.camp-title {
  flex: 1;
  font-size: var(--font-size-subtitle);
  font-weight: 500;
  color: #202124;
  margin-right: var(--grid-3);
  line-height: var(--line-height-tight);
}

.reminder-status {
  padding: 4px var(--grid-2);
  border-radius: 4px;
  font-size: var(--font-size-caption);
  font-weight: 500;
  line-height: var(--line-height-normal);
}

.reminder-status.pending {
  background-color: #E8F0FE;
  color: #1A73E8;
}

.reminder-status.sent {
  background-color: #E6F4EA;
  color: #34A853;
}

.reminder-status.expired {
  background-color: #FCE8E6;
  color: #EA4335;
}

.reminder-info {
  margin-bottom: var(--grid-3);
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--grid-2);
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  margin-right: var(--grid-2);
}

.info-text {
  font-size: var(--font-size-body);
  color: #5F6368;
  flex: 1;
  line-height: var(--line-height-normal);
}

.reminder-actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--grid-2);
  padding-top: var(--grid-3);
  border-top: 1px solid rgba(95, 99, 104, 0.2);
}

.action-btn {
  font-size: var(--font-size-body);
  padding: 6px var(--grid-3);
  border-radius: 8px;
  min-width: 80px;
  line-height: var(--line-height-normal);
}

.action-btn.secondary {
  background-color: rgba(255, 255, 255, 0.96);
  color: var(--primary-color);
  border: 1px solid var(--primary-color);
}

.action-btn.danger {
  background-color: rgba(255, 255, 255, 0.96);
  color: var(--error-color);
  border: 1px solid var(--error-color);
}

.action-btn::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 0;
  text-align: center;
}

.empty-text {
  font-size: var(--font-size-subtitle);
  color: #5F6368;
  margin-top: var(--grid-4);
  margin-bottom: var(--grid-2);
  line-height: var(--line-height-tight);
}

.empty-subtext {
  font-size: var(--font-size-body);
  color: #80868B;
  line-height: var(--line-height-normal);
}
