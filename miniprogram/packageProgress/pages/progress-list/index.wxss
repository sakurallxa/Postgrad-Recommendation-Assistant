.page {
  padding: 24rpx;
  background: #f4f7fc;
  min-height: 100vh;
  box-sizing: border-box;
}

.tips {
  background: linear-gradient(160deg, #ffffff 0%, #f5f8ff 100%);
  border: 1px solid rgba(26, 115, 232, 0.2);
  color: #2f5fae;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.center-switch {
  display: flex;
  background: rgba(26, 115, 232, 0.08);
  border-radius: 999rpx;
  padding: 4rpx;
  margin-bottom: 20rpx;
  border: 1px solid rgba(26, 115, 232, 0.14);
}

.center-switch-item {
  flex: 1;
  text-align: center;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #5f6368;
}

.center-switch-item.active {
  background: #ffffff;
  color: #1a73e8;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(26, 115, 232, 0.12);
}

.school-sub-entry {
  background: linear-gradient(160deg, #ffffff 0%, #f6f9ff 100%);
  border: 1px solid rgba(26, 115, 232, 0.16);
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin: 4rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 22rpx rgba(26, 115, 232, 0.1);
}

.school-sub-entry:active {
  transform: translateY(-2rpx);
}

.school-sub-entry-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.school-sub-entry-title {
  color: #1c2a3f;
  font-size: 27rpx;
  font-weight: 600;
}

.school-sub-entry-desc {
  color: #72819a;
  font-size: 22rpx;
}

.school-sub-entry-arrow {
  color: #1a73e8;
  font-size: 30rpx;
  font-weight: 600;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #152033;
  margin: 20rpx 0 12rpx;
}

.alert-section {
  margin-bottom: 20rpx;
}

.alert-item {
  background: linear-gradient(160deg, #ffffff 0%, #f6f9ff 100%);
  border: 1px solid rgba(26, 115, 232, 0.16);
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 8rpx 22rpx rgba(26, 115, 232, 0.1);
}

.alert-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.alert-title {
  font-size: 28rpx;
  color: #1c2a3f;
  font-weight: 600;
}

.alert-content {
  color: #4b5a73;
  font-size: 24rpx;
  line-height: 1.5;
}

.alert-time {
  margin-top: 10rpx;
  color: #8a97ad;
  font-size: 22rpx;
}

.confidence {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #f0f3f8;
  color: #4b5a73;
}

.confidence.high {
  background: #e8f8ef;
  color: #198b4c;
}

.confidence.medium {
  background: #fff4df;
  color: #9a6a00;
}

.confidence.low {
  background: #ffe8e8;
  color: #b42318;
}

.progress-item {
  background: linear-gradient(160deg, #ffffff 0%, #f6f9ff 100%);
  border: 1px solid rgba(26, 115, 232, 0.16);
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 8rpx 22rpx rgba(26, 115, 232, 0.1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.progress-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 28rpx rgba(26, 115, 232, 0.14);
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.title {
  flex: 1;
  font-size: 28rpx;
  color: #1c2a3f;
  font-weight: 600;
  line-height: 1.4;
}

.status {
  font-size: 22rpx;
  color: #1d5eea;
  background: #edf3ff;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.meta-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  color: #74829a;
  font-size: 22rpx;
  gap: 18rpx;
}

.next-action {
  margin-top: 10rpx;
  color: #23314a;
  font-size: 24rpx;
  display: block;
}

.empty {
  background: linear-gradient(160deg, #ffffff 0%, #f6f9ff 100%);
  border: 1px solid rgba(26, 115, 232, 0.16);
  border-radius: 14rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  color: #52617b;
  font-size: 24rpx;
  line-height: 1.6;
}

.primary-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #4285f4 100%);
  color: #fff;
  border-radius: 12rpx;
}
