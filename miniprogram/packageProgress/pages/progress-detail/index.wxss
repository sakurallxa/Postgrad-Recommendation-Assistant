.page {
  min-height: 100vh;
  background: #f6f8fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.tips {
  background: #eef5ff;
  color: #2f5fae;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.loading {
  text-align: center;
  color: #5f6e86;
  padding: 80rpx 0;
}

.card {
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  color: #1c2a3f;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.meta {
  display: block;
  color: #72819a;
  font-size: 23rpx;
  margin-top: 6rpx;
}

.status-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-label {
  color: #5c6b82;
  font-size: 24rpx;
}

.status-value {
  color: #1d5eea;
  font-size: 24rpx;
  background: #edf3ff;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.next-action {
  margin-top: 12rpx;
  color: #2a3a53;
  font-size: 24rpx;
  line-height: 1.5;
}

.section {
  background: #fff;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  color: #1c2a3f;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  border-radius: 999rpx;
  background: #edf3ff;
  color: #245ad6;
  font-size: 23rpx;
  padding: 10rpx 18rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  color: #2f3f5a;
  font-size: 24rpx;
}

.primary-btn {
  margin-top: 14rpx;
  border-radius: 10rpx;
  background: #1d5eea;
  color: #fff;
}

.alert-item {
  border: 1px solid #edf1f7;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-bottom: 12rpx;
}

.alert-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.alert-title {
  font-size: 26rpx;
  color: #1e2c40;
  font-weight: 600;
}

.alert-content {
  display: block;
  color: #4d5b72;
  font-size: 24rpx;
  line-height: 1.5;
}

.alert-time {
  display: block;
  color: #8996ad;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.confidence {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #f0f3f8;
  color: #4b5a73;
}

.confidence.high {
  background: #e8f8ef;
  color: #198b4c;
}

.confidence.medium {
  background: #fff4df;
  color: #9a6a00;
}

.confidence.low {
  background: #ffe8e8;
  color: #b42318;
}

.action-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.line-btn {
  border-radius: 10rpx;
  color: #36558a;
  background: #f3f6fb;
  font-size: 22rpx;
  padding: 0 16rpx;
}

.fill-btn {
  border-radius: 10rpx;
  color: #fff;
  background: #1d5eea;
  font-size: 22rpx;
  padding: 0 16rpx;
}

.log-item {
  border-left: 3px solid #dbe5f8;
  padding: 8rpx 0 8rpx 12rpx;
  margin-bottom: 10rpx;
}

.log-status {
  display: block;
  color: #2c3c56;
  font-size: 24rpx;
  font-weight: 600;
}

.log-time {
  display: block;
  color: #7d8ca3;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.log-note {
  display: block;
  color: #5d6d87;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.empty {
  color: #7b889f;
  font-size: 24rpx;
  padding: 10rpx 0;
}
