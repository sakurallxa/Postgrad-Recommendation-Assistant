/* 院校选择页样式 */
.selector-page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 64px; /* 为底部操作栏留出空间 */
}

/* 搜索框 */
.search-section {
  padding: 16px;
  background-color: #FFFFFF;
  border-bottom: 1px solid #DADCE0;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #F8F9FA;
  border-radius: 8px;
  padding: 8px 12px;
}

.search-icon {
  margin-right: 8px;
}

.search-input {
  flex: 1;
  font-size: 16px;
  color: #202124;
  padding: 4px 0;
}

.search-placeholder {
  color: #9AA0A6;
}

/* 筛选区 */
.filter-section {
  background-color: #FFFFFF;
  padding: 12px 16px;
  border-bottom: 1px solid #DADCE0;
}

.filter-group {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12px;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-tag {
  padding: 6px 12px;
  border: 1px solid #DADCE0;
  border-radius: 16px;
  font-size: 14px;
  color: #5F6368;
  margin-right: 8px;
  margin-bottom: 8px;
  background-color: #FFFFFF;
}

.filter-tag.active {
  background-color: #E8F0FE;
  border-color: #1A73E8;
  color: #1A73E8;
}

/* 已选院校区 */
.selected-section {
  background-color: #FFFFFF;
  padding: 16px;
  margin-top: 12px;
  border-radius: 12px;
  margin-left: 16px;
  margin-right: 16px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}

.selected-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.selected-title {
  font-size: 16px;
  font-weight: 500;
  color: #202124;
}

.toggle-btn {
  font-size: 14px;
  color: #1A73E8;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.selected-tag {
  display: flex;
  align-items: center;
  background-color: #E8F0FE;
  padding: 6px 10px;
  border-radius: 16px;
  font-size: 14px;
  color: #1A73E8;
}

.tag-text {
  margin-right: 6px;
}

.tag-close {
  margin-left: 4px;
}

/* 院校列表区 */
.university-list-section {
  margin-top: 12px;
  background-color: #FFFFFF;
  border-radius: 12px;
  margin-left: 16px;
  margin-right: 16px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  overflow: hidden;
}

.university-group {
  border-bottom: 1px solid #DADCE0;
}

.university-group:last-child {
  border-bottom: none;
}

.group-letter {
  font-size: 14px;
  font-weight: 600;
  color: #1A73E8;
  padding: 12px 16px 8px;
  background-color: #F8F9FA;
}

.university-list {
  padding-bottom: 8px;
}

.university-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid #F0F0F0;
}

.university-item:last-child {
  border-bottom: none;
}

.university-info {
  flex: 1;
}

.university-name {
  font-size: 16px;
  color: #202124;
  margin-bottom: 4px;
  display: block;
}

.university-level {
  font-size: 12px;
  color: #80868B;
  background-color: #F8F9FA;
  padding: 2px 6px;
  border-radius: 4px;
  display: inline-block;
}

.university-checkbox {
  margin-left: 16px;
}

.checkbox {
  width: 20px;
  height: 20px;
  border: 2px solid #DADCE0;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
}

.checkbox.checked {
  background-color: #1A73E8;
  border-color: #1A73E8;
}

/* 加载状态 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
  background-color: #FFFFFF;
  margin: 12px 16px;
  border-radius: 12px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid #E8F0FE;
  border-top: 3px solid #1A73E8;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 12px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: #5F6368;
}

/* 空状态 */
.empty-section {
  padding: 60px 0;
  text-align: center;
  color: #80868B;
  font-size: 14px;
}

/* 底部操作区 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 10px 16px;
  border-top: 1px solid #DADCE0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 52px;
  box-sizing: border-box;
}

.selected-count {
  font-size: 14px;
  color: #5F6368;
}

.confirm-btn {
  background-color: #1A73E8;
  color: #FFFFFF;
  border-radius: 20px;
  padding: 8px 20px;
  font-size: 14px;
  font-weight: 500;
  min-width: 90px;
  text-align: center;
  line-height: 1.4;
}

.confirm-btn::after {
  border: none;
}
