/* 院校选择页样式 */
.selector-page {
  min-height: 100vh;
  background-color: var(--surface-page);
  padding-bottom: 64px; /* 为底部操作栏留出空间 */
}

/* 搜索框 */
.search-section {
  padding: var(--grid-4);
  background: var(--surface-card-bg-soft);
  border-bottom: 1px solid rgba(26, 115, 232, 0.14);
}

.search-box {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.92);
  border-radius: 10px;
  border: 1px solid rgba(95, 99, 104, 0.2);
  padding: var(--grid-2) var(--grid-3);
}

.search-icon {
  margin-right: 8px;
}

.search-input {
  flex: 1;
  font-size: var(--font-size-subtitle);
  color: #202124;
  padding: var(--grid-1) 0;
  line-height: var(--line-height-normal);
}

.search-placeholder {
  color: #9AA0A6;
}

/* 筛选区 */
.filter-section {
  background: var(--surface-card-bg);
  padding: var(--grid-3) var(--grid-4);
  border-bottom: 1px solid rgba(26, 115, 232, 0.14);
  border-top: 1px solid rgba(26, 115, 232, 0.1);
}

.filter-group {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: var(--grid-3);
}

.filter-group:last-child {
  margin-bottom: 0;
}

.province-filter-group {
  margin-right: -16px;
}

.province-scroll {
  white-space: nowrap;
  padding-right: 16px;
}

.filter-tag {
  padding: 6px var(--grid-3);
  border: 1px solid rgba(95, 99, 104, 0.24);
  border-radius: 16px;
  font-size: var(--font-size-body);
  color: #5F6368;
  margin-right: var(--grid-2);
  margin-bottom: var(--grid-2);
  background-color: rgba(255, 255, 255, 0.96);
}

.province-filter-tag {
  display: inline-block;
  margin-bottom: 0;
}

.filter-tag.active {
  background-color: var(--surface-chip-bg);
  border-color: #1A73E8;
  color: #1A73E8;
  font-weight: 600;
}

/* 已选院校区 */
.selected-section {
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  padding: var(--grid-4);
  margin-top: var(--grid-3);
  border-radius: 16px;
  margin-left: var(--grid-4);
  margin-right: var(--grid-4);
  box-shadow: var(--shadow-2);
}

.selected-header {
  position: relative;
  min-height: 24px;
  padding-right: 132px;
  margin-bottom: var(--grid-3);
}

.selected-actions {
  position: absolute;
  right: 0;
  top: 0;
  display: flex;
  align-items: center;
  gap: 12px;
}

.selected-title {
  font-size: var(--font-size-subtitle);
  font-weight: 500;
  color: #202124;
  white-space: nowrap;
  line-height: var(--line-height-tight);
}

.clear-btn {
  font-size: var(--font-size-caption);
  color: #EA4335;
  line-height: 24px;
  padding: 0;
  background: transparent;
  white-space: nowrap;
}

.toggle-btn {
  font-size: var(--font-size-body);
  color: #1A73E8;
  line-height: 24px;
  white-space: nowrap;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--grid-2);
}

.selected-tag {
  display: flex;
  align-items: center;
  background-color: var(--surface-chip-bg);
  border: 1px solid rgba(26, 115, 232, 0.2);
  padding: 6px 10px;
  border-radius: 16px;
  font-size: var(--font-size-body);
  color: #1A73E8;
}

.tag-text {
  margin-right: 6px;
}

.tag-close {
  font-size: 16px;
  line-height: 1;
  color: #1A73E8;
}

.selected-empty {
  padding: 4px 0;
}

.selected-empty-text {
  font-size: var(--font-size-note);
  color: #80868B;
}

/* 院校列表区 */
.university-list-section {
  margin-top: var(--grid-3);
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  border-radius: 16px;
  margin-left: var(--grid-4);
  margin-right: var(--grid-4);
  box-shadow: var(--shadow-2);
  overflow: hidden;
}

.university-group {
  border-bottom: 1px solid #DADCE0;
}

.university-group:last-child {
  border-bottom: none;
}

.group-letter {
  font-size: var(--font-size-body);
  font-weight: 600;
  color: #1A73E8;
  padding: var(--grid-3) var(--grid-4) var(--grid-2);
  background-color: rgba(26, 115, 232, 0.06);
}

.university-list {
  padding-bottom: 8px;
}

.university-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--grid-3) var(--grid-4);
  border-bottom: 1px solid rgba(95, 99, 104, 0.16);
  transition: background-color 0.2s ease;
}

.university-item:last-child {
  border-bottom: none;
}

.university-item:active {
  background-color: rgba(26, 115, 232, 0.08);
}

.university-info {
  flex: 1;
}

.university-name {
  font-size: var(--font-size-subtitle);
  color: #202124;
  margin-bottom: var(--grid-1);
  display: block;
  line-height: var(--line-height-tight);
}

.university-level {
  font-size: var(--font-size-caption);
  color: #80868B;
  background-color: #F8F9FA;
  padding: 2px 6px;
  border-radius: 4px;
  display: inline-block;
}

.university-checkbox {
  margin-left: var(--grid-4);
}

.checkbox {
  width: 20px;
  height: 20px;
  border: 2px solid #DADCE0;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
}

.checkbox.checked {
  background-color: #1A73E8;
  border-color: #1A73E8;
}

/* 加载状态 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  margin: 12px 16px;
  border-radius: 16px;
  box-shadow: var(--shadow-2);
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid #E8F0FE;
  border-top: 3px solid #1A73E8;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 12px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--font-size-body);
  color: #5F6368;
  line-height: var(--line-height-normal);
}

/* 空状态 */
.empty-section {
  padding: 60px 0;
  text-align: center;
  color: #80868B;
  font-size: var(--font-size-body);
  line-height: var(--line-height-normal);
}

/* 底部操作区 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.96);
  padding: 10px var(--grid-4);
  border-top: 1px solid rgba(26, 115, 232, 0.16);
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 52px;
  box-sizing: border-box;
  box-shadow: 0 -8px 22px rgba(26, 115, 232, 0.12);
}

.selected-count {
  font-size: var(--font-size-body);
  color: #5F6368;
}

.confirm-btn {
  background: linear-gradient(135deg, #1a73e8 0%, #4285f4 100%);
  color: #FFFFFF;
  border-radius: 20px;
  padding: 8px 20px;
  font-size: var(--font-size-body);
  font-weight: 500;
  min-width: 90px;
  text-align: center;
  line-height: 1.4;
  margin: 0 0 0 auto;
}

.confirm-btn::after {
  border: none;
}

/* MVP β: 5所重点校的视觉标识 */
.university-item.priority {
  background: linear-gradient(to right, rgba(245, 167, 66, 0.05), transparent);
  border-left: 6rpx solid #f5a742;
  padding-left: 18rpx;
}
.university-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}
.priority-star {
  color: #f5a742;
  font-size: 28rpx;
  line-height: 1;
}
.priority-badge {
  font-size: 20rpx;
  color: #b35e00;
  background: rgba(245, 167, 66, 0.18);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  line-height: 1.2;
}
