<view class="selector-page">
  <!-- 搜索框 -->
  <view class="search-section">
    <view class="search-box">
      <icon class="search-icon" type="search" size="20" color="#9AA0A6" />
      <input 
        class="search-input" 
        placeholder="搜索院校名称..." 
        placeholder-class="search-placeholder"
        bindinput="onSearchInput"
      />
    </view>
  </view>

  <!-- 筛选区 -->
  <view class="filter-section">
    <view class="filter-group">
      <view 
        wx:for="{{regionFilters}}" 
        wx:key="value"
        class="filter-tag {{selectedRegion === item.value ? 'active' : ''}}"
        bindtap="onRegionFilterTap"
        data-value="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
    <view class="filter-group province-filter-group">
      <scroll-view class="province-scroll" scroll-x>
        <view 
          wx:for="{{provinceFilters}}" 
          wx:key="value"
          class="filter-tag province-filter-tag {{selectedProvince === item.value ? 'active' : ''}}"
          bindtap="onProvinceFilterTap"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </scroll-view>
    </view>
    <view class="filter-group">
      <view 
        wx:for="{{levelFilters}}" 
        wx:key="value"
        class="filter-tag {{selectedLevel === item.value ? 'active' : ''}}"
        bindtap="onLevelFilterTap"
        data-value="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <!-- 已选院校区 -->
  <view class="selected-section">
    <view class="selected-header">
      <view class="selected-title">已选院校 ({{selectedUniversities.length}})</view>
      <view class="selected-actions">
        <view
          wx:if="{{selectedUniversities.length > 0}}"
          class="clear-btn"
          bindtap="onClearSelectedUniversities"
        >
          清空已选
        </view>
        <view class="toggle-btn" bindtap="toggleSelectedSection">
          {{isSelectedSectionExpanded ? '收起 ▲' : '展开 ▼'}}
        </view>
      </view>
    </view>
    <view class="selected-tags" wx:if="{{isSelectedSectionExpanded && selectedUniversities.length > 0}}">
      <view 
        wx:for="{{selectedUniversities}}" 
        wx:key="id"
        class="selected-tag"
        catchtap="onRemoveSelectedUniversity"
        data-id="{{item.id}}"
      >
        <text class="tag-text">{{item.name}}</text>
        <text class="tag-close">×</text>
      </view>
    </view>
    <view wx:if="{{isSelectedSectionExpanded && selectedUniversities.length === 0}}" class="selected-empty">
      <text class="selected-empty-text">暂未选择院校，点击下方列表可添加</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-section">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 院校列表区 -->
  <view wx:else class="university-list-section">
    <view wx:if="{{groupedUniversities.length === 0}}" class="empty-section">
      <text class="empty-text">暂无匹配的院校</text>
    </view>
    <view wx:else class="university-list-content">
      <view 
        wx:for="{{groupedUniversities}}" 
        wx:key="letter"
        class="university-group"
      >
        <view class="group-letter">{{item.letter}}</view>
        <view class="university-list">
          <view 
            wx:for="{{item.universities}}" 
            wx:key="id"
            class="university-item"
            bindtap="onUniversityTap"
            data-id="{{item.id}}"
          >
            <view class="university-info">
              <text class="university-name">{{item.name}}</text>
              <text class="university-level" wx:if="{{item.level}}">{{item.level}}</text>
            </view>
            <view class="university-checkbox">
              <view class="checkbox {{isUniversitySelected(item.id) ? 'checked' : ''}}">
                <icon wx:if="{{isUniversitySelected(item.id)}}" type="success" size="16" color="#1A73E8" />
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="bottom-action-bar">
    <view class="selected-count">已选择 {{selectedUniversities.length}} 所院校</view>
    <button class="confirm-btn" bindtap="onConfirmSelection">
      确认选择
    </button>
  </view>
</view>
