/* 专业列表页样式 */
.major-list-page {
  min-height: 100vh;
  background-color: var(--surface-page);
  padding-bottom: 70px; /* 为底部操作栏留出空间 */
}

/* 搜索框 */
.search-section {
  padding: var(--grid-4);
  background: var(--surface-card-bg-soft);
  border-bottom: 1px solid rgba(26, 115, 232, 0.14);
}

.search-box {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.92);
  border-radius: 10px;
  border: 1px solid rgba(95, 99, 104, 0.2);
  padding: var(--grid-2) var(--grid-3);
}

.search-icon {
  margin-right: 8px;
}

.search-input {
  flex: 1;
  font-size: var(--font-size-subtitle);
  color: #202124;
  padding: var(--grid-1) 0;
  line-height: var(--line-height-normal);
}

.search-placeholder {
  color: #9AA0A6;
}

/* 学科门类筛选 */
.category-section {
  background: var(--surface-card-bg);
  padding: var(--grid-3) 0;
  border-bottom: 1px solid rgba(26, 115, 232, 0.14);
}

.category-scroll {
  white-space: nowrap;
  padding-left: var(--grid-4);
  padding-right: var(--grid-4);
}

.category-tag {
  display: inline-block;
  padding: 6px var(--grid-4);
  border: 1px solid rgba(95, 99, 104, 0.24);
  border-radius: 16px;
  font-size: var(--font-size-body);
  color: #5F6368;
  margin-right: var(--grid-2);
  background-color: rgba(255, 255, 255, 0.96);
}

.category-tag.active {
  background-color: var(--surface-chip-bg);
  border-color: #1A73E8;
  color: #1A73E8;
  font-weight: 600;
}

/* 已选专业区 */
.selected-section {
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  padding: var(--grid-4);
  margin-top: var(--grid-3);
  border-radius: 16px;
  margin-left: var(--grid-4);
  margin-right: var(--grid-4);
  box-shadow: var(--shadow-2);
}

.selected-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--grid-3);
}

.selected-title {
  font-size: var(--font-size-subtitle);
  font-weight: 500;
  color: #202124;
  line-height: var(--line-height-tight);
}

.toggle-btn {
  font-size: var(--font-size-body);
  color: #1A73E8;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--grid-2);
}

.selected-tag {
  display: flex;
  align-items: center;
  background-color: var(--surface-chip-bg);
  border: 1px solid rgba(26, 115, 232, 0.2);
  padding: 6px 10px;
  border-radius: 16px;
  font-size: var(--font-size-body);
  color: #1A73E8;
}

.tag-text {
  margin-right: var(--grid-2);
}

.tag-close {
  margin-left: 4px;
}

/* 专业列表区 */
.major-list-section {
  margin-top: var(--grid-3);
  background: var(--surface-card-bg);
  border: 1px solid var(--surface-card-border);
  border-radius: 16px;
  margin-left: var(--grid-4);
  margin-right: var(--grid-4);
  box-shadow: var(--shadow-2);
  overflow: hidden;
}

.major-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--grid-4);
  border-bottom: 1px solid rgba(95, 99, 104, 0.16);
  transition: background-color 0.2s ease;
}

.major-item:last-child {
  border-bottom: none;
}

.major-item:active {
  background-color: rgba(26, 115, 232, 0.08);
}

.major-info {
  flex: 1;
}

.major-name {
  font-size: var(--font-size-subtitle);
  color: #202124;
  margin-bottom: var(--grid-1);
  display: block;
  line-height: var(--line-height-tight);
}

.major-category {
  font-size: var(--font-size-caption);
  color: #80868B;
  background-color: #F8F9FA;
  padding: 2px 6px;
  border-radius: 4px;
  display: inline-block;
}

.major-checkbox {
  margin-left: var(--grid-4);
}

.checkbox {
  width: 20px;
  height: 20px;
  border: 2px solid #DADCE0;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
}

.checkbox.checked {
  background-color: #1A73E8;
  border-color: #1A73E8;
}

/* 底部操作区 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.96);
  padding: var(--grid-3) var(--grid-4);
  border-top: 1px solid rgba(26, 115, 232, 0.16);
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 56px;
  box-shadow: 0 -8px 22px rgba(26, 115, 232, 0.12);
}

.selected-count {
  font-size: var(--font-size-body);
  color: #5F6368;
  line-height: var(--line-height-normal);
}

.confirm-btn {
  background: linear-gradient(135deg, #1a73e8 0%, #4285f4 100%);
  color: #FFFFFF;
  border-radius: 10px;
  padding: 8px 24px;
  font-size: var(--font-size-subtitle);
  font-weight: 500;
  min-width: 120px;
  text-align: center;
  margin: 0;
}

.confirm-btn::after {
  border: none;
}
