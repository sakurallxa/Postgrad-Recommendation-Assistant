.page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
}
.tip-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #F5F3FF;
  border-bottom: 1rpx solid rgba(79, 70, 229, 0.12);
}
.tip-text {
  font-size: 24rpx;
  color: var(--text-secondary, #666);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}
.tip-copy {
  font-size: 24rpx;
  color: var(--color-primary, #4F46E5);
  font-weight: 500;
  padding: 4rpx 16rpx;
  border: 1rpx solid var(--color-primary, #4F46E5);
  border-radius: 999rpx;
  flex-shrink: 0;
}
.tip-copy:active { opacity: 0.7; }

web-view { flex: 1; }

/* 右下角悬浮"复制链接"按钮 */
.floating-copy {
  position: fixed;
  right: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 48rpx);
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: rgba(0, 0, 0, 0.78);
  color: #FFFFFF;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
  z-index: 100;
}
.floating-copy:active { opacity: 0.85; transform: scale(0.97); }
.floating-copy-icon { font-size: 26rpx; }
.floating-copy-text { font-size: 26rpx; font-weight: 500; }

/* 兜底 */
.fallback {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48rpx;
  box-sizing: border-box;
}
.fallback-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}
.fallback-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.fallback-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 32rpx;
}
.fallback-url {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 16rpx;
  font-size: 22rpx;
  color: #4F46E5;
  word-break: break-all;
  max-width: 100%;
  margin-bottom: 32rpx;
}
.fallback-btn {
  padding: 20rpx 48rpx;
  background: #4F46E5;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 999rpx;
}
.fallback-btn:active { opacity: 0.85; }
