.page {
  padding: var(--space-4) var(--space-3) calc(env(safe-area-inset-bottom) + 200rpx);
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  padding: var(--space-2) var(--space-2) var(--space-4);
}
.hero-title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-bold);
  margin-bottom: var(--space-1);
}
.hero-subtitle {
  font-size: var(--text-base);
  color: var(--text-secondary);
}
.hero-emph {
  color: var(--color-primary);
  font-weight: var(--weight-semibold);
}
.hero-tip {
  margin-top: 8rpx;
  font-size: var(--text-xs);
  color: var(--color-warning);
}

/* AI 推荐卡 */
.recommend-card {
  background: linear-gradient(135deg, rgba(79, 70, 229, 0.06), rgba(79, 70, 229, 0.02));
  border: 2rpx solid var(--color-primary-soft);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-4);
}
.recommend-head {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
}
.recommend-icon { font-size: 36rpx; }
.recommend-title {
  font-size: var(--text-sm);
  color: var(--color-primary);
  font-weight: var(--weight-medium);
}
.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
}
.recommend-chip {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: var(--bg-surface);
  border: 2rpx solid var(--color-primary-soft);
  border-radius: var(--radius-pill);
  font-size: var(--text-xs);
  color: var(--text-primary);
}
.recommend-action {
  text-align: center;
  padding: var(--space-2);
  color: var(--color-primary);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  border-top: 1rpx dashed var(--color-primary-soft);
}

/* 学校块 */
.school-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.school-block {
  background: var(--bg-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.school-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-3) var(--space-4);
}
.school-head:active { background: var(--bg-muted); }
.school-name {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}
.school-name-text {
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}
.school-count {
  font-size: var(--text-xs);
  background: var(--color-primary-soft);
  color: var(--color-primary);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-pill);
}
.school-toggle {
  color: var(--text-tertiary);
  font-size: 32rpx;
}

/* 院系列表 */
.dept-list {
  border-top: 1rpx solid var(--border-light);
}
.dept-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-3) var(--space-4);
  border-bottom: 1rpx solid var(--border-light);
}
.dept-item:last-child { border-bottom: none; }
.dept-item:active { background: var(--bg-muted); }
.dept-item.selected { background: var(--color-primary-soft); }
.dept-info { flex: 1; min-width: 0; }
.dept-name {
  font-size: var(--text-base);
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.dept-majors {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.dept-check {
  flex-shrink: 0;
  margin-left: var(--space-2);
}
.dept-check-box {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--border-strong);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  color: #FFFFFF;
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
}
.dept-check-box.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* 底部 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-surface);
  padding: var(--space-3) var(--space-3) calc(env(safe-area-inset-bottom) + var(--space-3));
  display: flex;
  align-items: center;
  gap: var(--space-3);
  box-shadow: 0 -4rpx 16rpx rgba(17, 24, 39, 0.04);
}
.bottom-info {
  flex: 1;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}
.bottom-info-emph {
  color: var(--color-primary);
  font-weight: var(--weight-bold);
  font-size: var(--text-md);
}
.bottom-save {
  flex: 1.5;
  height: 88rpx;
  font-size: var(--text-md);
  font-weight: var(--weight-medium);
}
