.page {
  padding: var(--space-4) var(--space-3) calc(env(safe-area-inset-bottom) + 200rpx);
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  padding: var(--space-2) var(--space-3) var(--space-3);
}
.hero-title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-bold);
  margin-bottom: var(--space-2);
  letter-spacing: -0.5rpx;
}
.hero-subtitle {
  font-size: var(--text-base);
  color: var(--text-secondary);
  line-height: var(--leading-relaxed);
}
.hero-emph {
  color: var(--color-primary);
  font-weight: var(--weight-semibold);
}
.hero-tip {
  margin-top: var(--space-2);
  font-size: var(--text-xs);
  color: var(--color-warning);
  background: var(--color-warning-soft);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-md);
  display: inline-block;
}

/* 层级过滤 chip 行（全部/985/211/双一流/其他）*/
.level-bar {
  white-space: nowrap;
  padding: 0 var(--space-2) var(--space-2);
}
.level-chip {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  background: var(--bg-surface);
  color: var(--text-secondary);
  font-size: 26rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border-light);
  transition: background 0.15s, color 0.15s;
}
.level-chip:active { opacity: 0.85; }
.level-chip-active {
  background: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
  font-weight: var(--weight-semibold);
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--bg-surface);
  border-radius: var(--radius-pill);
  padding: 20rpx 28rpx;
  margin: 0 var(--space-2) var(--space-3);
  box-shadow: var(--shadow-xs);
  gap: var(--space-2);
}
.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  font-size: var(--text-sm);
  color: var(--text-primary);
  min-height: 56rpx;
}
.search-clear {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: var(--bg-muted);
  color: var(--text-tertiary);
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-search {
  padding: var(--space-5);
  text-align: center;
  color: var(--text-tertiary);
  font-size: var(--text-sm);
}

/* 学校字母前缀 */
.school-letter {
  display: inline-flex;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  align-items: center;
  justify-content: center;
  margin-right: var(--space-2);
  flex-shrink: 0;
}

/* AI 推荐卡 */
.recommend-card {
  background: linear-gradient(135deg, rgba(79, 70, 229, 0.06), rgba(79, 70, 229, 0.02));
  border: 2rpx solid var(--color-primary-soft);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-4);
}
.recommend-head {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
}
.recommend-icon { font-size: 36rpx; }
.recommend-title {
  font-size: var(--text-sm);
  color: var(--color-primary);
  font-weight: var(--weight-medium);
}
.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
}
.recommend-chip {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: var(--bg-surface);
  border: 2rpx solid var(--color-primary-soft);
  border-radius: var(--radius-pill);
  font-size: var(--text-xs);
  color: var(--text-primary);
}
.recommend-action {
  text-align: center;
  padding: var(--space-2);
  color: var(--color-primary);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  border-top: 1rpx dashed var(--color-primary-soft);
}

/* 学校块 */
.school-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.school-block {
  background: var(--bg-surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.school-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-4);
}
.school-head:active { background: var(--bg-muted); }
.school-name {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}
.school-name-text {
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}
.school-count {
  font-size: var(--text-xs);
  background: var(--color-primary-soft);
  color: var(--color-primary);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-pill);
}
.school-toggle {
  color: var(--text-tertiary);
  font-size: 32rpx;
}

/* 院系列表 */
.dept-list {
  border-top: 1rpx solid var(--border-light);
}
.dept-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-3) var(--space-4);
  border-bottom: 1rpx solid var(--border-light);
}
.dept-item:last-child { border-bottom: none; }
.dept-item:active { background: var(--bg-muted); }
.dept-item.selected { background: var(--color-primary-soft); }
.dept-info { flex: 1; min-width: 0; }
.dept-name {
  font-size: var(--text-base);
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.dept-majors {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.dept-check {
  flex-shrink: 0;
  margin-left: var(--space-2);
}
.dept-check-box {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--border-strong);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  color: #FFFFFF;
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
}
.dept-check-box.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* 底部 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-surface);
  padding: var(--space-3) var(--space-3) calc(env(safe-area-inset-bottom) + var(--space-3));
  display: flex;
  align-items: center;
  gap: var(--space-3);
  box-shadow: 0 -4rpx 16rpx rgba(17, 24, 39, 0.04);
}
.bottom-info {
  flex: 1;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}
.bottom-info-emph {
  color: var(--color-primary);
  font-weight: var(--weight-bold);
  font-size: var(--text-md);
}
.bottom-save {
  flex: 1.5;
  height: 88rpx;
  font-size: var(--text-md);
  font-weight: var(--weight-medium);
}

/* ============ 已选 chip 标签 ============ */
.chip-bar {
  white-space: nowrap;
  padding: var(--space-3) var(--space-2) var(--space-3);
  margin-bottom: var(--space-1);
}
.chip {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 12rpx 24rpx;
  margin-right: var(--space-2);
  background: var(--color-primary-soft);
  border: 2rpx solid transparent;
  border-radius: var(--radius-pill);
  font-size: var(--text-sm);
  color: var(--color-primary);
  font-weight: var(--weight-medium);
  max-width: 380rpx;
  transition: transform 0.15s;
}
.chip:active { transform: scale(0.96); }
.chip-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300rpx;
}
.chip-close {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: var(--weight-bold);
  line-height: 1;
  opacity: 0.65;
}

/* ============ 列表区 + 字母索引并排 ============ */
.list-area {
  display: flex;
  position: relative;
  flex: 1;
  min-height: 0;
}
.school-list-scroll {
  flex: 1;
  padding: 0 var(--space-3) 240rpx;
  box-sizing: border-box;
  max-height: 70vh;
}
/* 学校间距使用统一 token */
.school-list-scroll .school-block {
  margin-bottom: var(--space-3);
}
.school-list-scroll .school-block:last-child {
  margin-bottom: 0;
}
.letter-index {
  position: absolute;
  right: 4rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  padding: var(--space-2) 4rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-xs);
  z-index: 10;
}
.letter-item {
  font-size: 20rpx;
  color: var(--text-tertiary);
  width: 36rpx;
  height: 36rpx;
  text-align: center;
  line-height: 36rpx;
  font-weight: var(--weight-semibold);
  border-radius: 50%;
  transition: all 0.15s;
}
.letter-item.active {
  background: var(--color-primary);
  color: var(--bg-surface);
  transform: scale(1.15);
}
