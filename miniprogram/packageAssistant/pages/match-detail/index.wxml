<view class="page" wx:if="{{!loading}}">
  <!-- 顶部判断 -->
  <view class="judgement-card">
    <view class="judge-badge {{recommendationClass}}">
      <text class="judge-icon">{{recommendationIcon}}</text>
      <text class="judge-text">{{recommendationText}}</text>
    </view>
    <view wx:if="{{match.matchScore != null}}" class="judge-score">
      <text class="score-label">匹配度</text>
      <text class="score-value">{{match.matchScore}}</text>
      <text class="score-unit">%</text>
    </view>
    <view class="judge-reasoning" wx:if="{{match.reasoning}}">{{match.reasoning}}</view>
  </view>

  <!-- 学校院系 -->
  <view class="meta-card">
    <view class="meta-row">
      <text class="meta-label">学校</text>
      <text class="meta-value">{{match.camp.universityName || '—'}}</text>
    </view>
    <view class="meta-row" wx:if="{{match.camp.departmentName}}">
      <text class="meta-label">院系</text>
      <text class="meta-value">{{match.camp.departmentName}}</text>
    </view>
    <view class="meta-row" wx:elif="{{match.camp.isUniversityLevel}}">
      <text class="meta-label">范围</text>
      <text class="meta-value value-primary">全校通用 · 适用于全部院系</text>
    </view>
    <view class="meta-row">
      <text class="meta-label">类型</text>
      <text class="meta-value">{{match.campType === 'pre_recommendation' ? '预推免' : '夏令营'}}</text>
    </view>
    <view class="meta-row" wx:if="{{match.matchesUserMajor != null}}">
      <text class="meta-label">专业匹配</text>
      <text class="meta-value {{match.matchesUserMajor ? 'value-primary' : 'value-warning'}}">{{match.matchesUserMajor ? '匹配你的目标专业' : '不在你的目标专业'}}</text>
    </view>
  </view>

  <!-- 标题（只保留公告标题；AI 摘要已经在顶部 reasoning 里讲过了，不重复 + 避免长文本截断）-->
  <view class="title-card">
    <view class="card-title-row">
      <!-- 校徽：有 URL 显示图片，没有则降级为首字母 placeholder -->
      <image
        wx:if="{{match.camp.universityLogo}}"
        class="card-logo"
        src="{{match.camp.universityLogo}}"
        mode="aspectFit"
        binderror="onLogoError"
      />
      <view wx:else class="card-logo card-logo-placeholder">
        {{match.camp.universityName ? match.camp.universityName[0] : '校'}}
      </view>
      <view class="card-title">{{match.camp.title}}</view>
    </view>
  </view>

  <!-- 时间地点 -->
  <view class="info-card">
    <view class="info-row">
      <text class="info-icon">⏰</text>
      <view class="info-content">
        <text class="info-label">报名截止</text>
        <text class="info-value">{{deadlineText || '未提取到'}}</text>
      </view>
    </view>
    <view class="info-row" wx:if="{{campPeriodText}}">
      <text class="info-icon">📅</text>
      <view class="info-content">
        <text class="info-label">营期</text>
        <text class="info-value">{{campPeriodText}}</text>
      </view>
    </view>
    <view class="info-row" wx:if="{{match.extractedLocation}}">
      <text class="info-icon">📍</text>
      <view class="info-content">
        <text class="info-label">地点</text>
        <text class="info-value">{{match.extractedLocation}}</text>
      </view>
    </view>
  </view>

  <!-- 关键要求逐项 -->
  <view class="req-card" wx:if="{{match.keyRequirements.length > 0}}">
    <view class="req-card-title">要求逐项对比</view>
    <view
      class="req-row"
      wx:for="{{match.keyRequirements}}"
      wx:key="index"
    >
      <view class="req-icon-wrap req-icon-{{item.userMatch}}">
        {{requirementIcons[item.userMatch]}}
      </view>
      <view class="req-content">
        <view class="req-requirement">{{item.requirement}}</view>
        <view class="req-explanation" wx:if="{{item.explanation}}">{{item.explanation}}</view>
      </view>
    </view>
  </view>

  <!-- 跳转原文 -->
  <view class="source-card">
    <view class="source-text" bindtap="onViewSource">
      <view class="source-title">查看原文</view>
      <view class="source-url">{{match.camp.sourceUrl}}</view>
    </view>
    <view class="source-actions">
      <view class="source-action source-action-secondary" catchtap="onCopyLink">复制</view>
      <view class="source-action" catchtap="onViewSource">查看 ›</view>
    </view>
  </view>

  <!-- 提示：未收藏时引导用户从详情页收藏（这里 tap 是同步手势链路，可正常弹微信订阅消息授权）-->
  <view class="bookmark-hint" wx:if="{{match.userAction !== 'interested'}}">
    <text class="bookmark-hint-icon">🔔</text>
    <text class="bookmark-hint-text">点收藏可同时开启截止日微信提醒（7/5/3 天前）</text>
  </view>

  <!-- 底部操作：⭐ 收藏 / ✓ 我已申请
       两个状态完全独立：userAction='interested' 管收藏；isApplied 管申请。
       点其中一个不影响另一个。 -->
  <view class="bottom-bar">
    <view
      class="action-btn action-secondary {{match.userAction === 'interested' ? 'active-interested' : ''}}"
      bindtap="onBookmark"
    >
      {{match.userAction === 'interested' ? '⭐ 已收藏' : '⭐ 收藏'}}
    </view>
    <view
      class="action-btn action-primary {{match.isApplied ? 'active-applied' : ''}}"
      bindtap="onApplied"
    >
      {{match.isApplied ? '✓ 已申请' : '✓ 我已申请'}}
    </view>
  </view>
</view>

<view wx:else class="loading">
  <view class="skeleton skeleton-card"></view>
</view>
